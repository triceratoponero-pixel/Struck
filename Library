        HorizontalAlignment = Enum.HorizontalAlignment.Center,
        VerticalAlignment = Enum.VerticalAlignment.Center,
        Padding = UDim.new(0, 10)
    })
    
    local function CreatePromptButton(name, callback)
        local Btn = CreateInstance("TextButton", {
            Name = name,
            Parent = ButtonContainer,
            BackgroundColor3 = CurrentTheme.Accent,
            BorderSizePixel = 0,
            Size = UDim2.new(0, 100, 1, 0),
            Font = Enum.Font.GothamBold,
            Text = name,
            TextColor3 = Color3.fromRGB(255, 255, 255),
            TextSize = 14,
            AutoButtonColor = false
        })
        Corner(Btn, 6)
        
        Btn.MouseEnter:Connect(function()
            TweenObject(Btn, {BackgroundColor3 = Color3.fromRGB(CurrentTheme.Accent.R * 255 + 20, CurrentTheme.Accent.G * 255 + 20, CurrentTheme.Accent.B * 255 + 20)}, 0.2)
        end)
        
        Btn.MouseLeave:Connect(function()
            TweenObject(Btn, {BackgroundColor3 = CurrentTheme.Accent}, 0.2)
        end)
        
        Btn.MouseButton1Click:Connect(function()
            if callback then callback() end
            PromptHolder:Destroy()
        end)
        
        return Btn
    end
    
    if promptType == "Text" then
        CreatePromptButton(options or "Alright", nil)
    elseif promptType == "OneButton" and type(options) == "table" then
        CreatePromptButton(options[1], options[2])
    elseif promptType == "TwoButton" and type(options) == "table" then
        CreatePromptButton(options[1], options[2])
        CreatePromptButton(options[3], options[4])
    end
end

