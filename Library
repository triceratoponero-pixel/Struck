function Library:Notify(props)
	local title = props.Title or "Notification"
	local text = props.Content or props.Text or ""
	local duration = props.Duration or 5

	pcall(function()
		StarterGui:SetCore("SendNotification", {
			Title = title,
			Text = text,
			Duration = duration
		})
	end)
end

--------------------------------------------------------------------------------
-- 5. CONFIG / SAVEMANAGER IMPLEMENTATION
--------------------------------------------------------------------------------

function SaveManager:SetLibrary(lib)
	self.Library = lib
end

function SaveManager:SetIgnoreIndexes(indexes)
	for _, idx in ipairs(indexes) do
		self.IgnoreIndexes[idx] = true
	end
end

function SaveManager:IgnoreThemeSettings()
	self:SetIgnoreIndexes({"Theme", "Acrylic", "MinimizeKey"})
end

function SaveManager:SetFolder(folder)
	self.Folder = folder
	if not isfolder(folder) then
		makefolder(folder)
	end
end

function SaveManager:Save(name)
	if not isfolder(self.Folder) then makefolder(self.Folder) end

	local saveTable = {}
	for idx, opt in pairs(self.Library.Options) do
		if not self.IgnoreIndexes[idx] then
			saveTable[idx] = opt.Value
		end
	end

	local json = HttpService:JSONEncode(saveTable)
	writefile(self.Folder .. "/" .. name .. ".json", json)
	self.Library:Notify({ Title = "Save Manager", Content = "Successfully saved " .. name, Duration = 3 })
end

function SaveManager:Load(name)
	local path = self.Folder .. "/" .. name .. ".json"
	local data = readfile(path)
	if not data or data == "" then return end

	local success, decoded = pcall(function()
		return HttpService:JSONDecode(data)
	end)

	if success and type(decoded) == "table" then
		for idx, value in pairs(decoded) do
			local opt = self.Library.Options[idx]
			if opt and opt.Set then
				opt:Set(value)
			end
		end
		self.Library:Notify({ Title = "Save Manager", Content = "Successfully loaded " .. name, Duration = 3 })
	else
		self.Library:Notify({ Title = "Save Manager", Content = "Failed to decode configuration file.", Duration = 3 })
	end
end

function SaveManager:LoadAutoloadConfig()
	local autoLoadPath = self.Folder .. "/" .. self.AutoLoadFile
	local targetFile = readfile(autoLoadPath)
	if targetFile and targetFile ~= "" then
		self:Load(targetFile)
		return targetFile
	end
	return nil
end

function SaveManager:BuildConfigSection(tab)
	local section = tab:AddSection("Save Manager")

	local configInput = section:AddInput("SaveManager_Input", {
		Title = "Config Name",
		Placeholder = "MyConfig"
	})

	local availableConfigs = {}
	if isfolder(self.Folder) then
		for _, file in ipairs(listfiles(self.Folder)) do
			if file:match("%.json$") then
				local cleaned = file:gsub("\\", "/"):match("([^/]+)%.json$")
				if cleaned then table.insert(availableConfigs, cleaned) end
			end
		end
	end

	local configDropdown = section:AddDropdown("SaveManager_Dropdown", {
		Title = "Existing Configs",
		Values = availableConfigs
	})

	section:AddButton({
		Title = "Save Config",
		Callback = function()
			local name = self.Library.Options.SaveManager_Input.Value
			if name and name ~= "" then
				self:Save(name)
				-- Refresh list
				local updated = {}
				for _, file in ipairs(listfiles(self.Folder)) do
					if file:match("%.json$") then
						local cleaned = file:gsub("\\", "/"):match("([^/]+)%.json$")
						if cleaned then table.insert(updated, cleaned) end
					end
				end
				configDropdown:Refresh(updated)
			end
		end
	})

	section:AddButton({
		Title = "Load Config",
		Callback = function()
			local name = self.Library.Options.SaveManager_Dropdown.Value
			if name and name ~= "" then
				self:Load(name)
			end
		end
	})

	section:AddButton({
		Title = "Set Autoload",
		Callback = function()
			local name = self.Library.Options.SaveManager_Dropdown.Value
			if name and name ~= "" then
				writefile(self.Folder .. "/" .. self.AutoLoadFile, name)
				self.Library:Notify({ Title = "Save Manager", Content = "Autoload set to " .. name, Duration = 3 })
			end
		end
	})
end

--------------------------------------------------------------------------------
-- 6. INTERFACE MANAGER IMPLEMENTATION
--------------------------------------------------------------------------------

function InterfaceManager:SetLibrary(lib)
	self.Library = lib
end

function InterfaceManager:SetFolder(folder)
	self.Folder = folder
	if not isfolder(folder) then makefolder(folder) end
end

function InterfaceManager:BuildInterfaceSection(tab)
	local section = tab:AddSection("Interface Settings")
	
	section:AddDropdown("Interface_Theme", {
		Title = "Theme",
		Values = {"Dark", "Light", "Nord"},
		Default = self.Library.Theme,
		Callback = function(v)
			self.Library.Theme = v
			-- Advanced visual mappings can be attached to this state modification
		end
	})

	section:AddToggle("Interface_Acrylic", {
		Title = "Acrylic UI",
		Default = self.Library.Acrylic,
		Callback = function(v)
			self.Library.Acrylic = v
		end
	})
end

return Library
