local Players = game:GetService("Players")
local HttpService = game:GetService("HttpService")

local Library = {}
Library.Options = {
    Theme = "Dark",
    Acrylic = true,
    MinimizeKey = Enum.KeyCode.RightShift,
    TabWidth = 140,
    TabHeight = 80,
    DefaultWindowSize = UDim2.new(0, 650, 0, 350),
}
Library.Config = {}

local function safeIsFile(path)
    if type(isfile) ~= "function" then
        return false
    end
    local ok, result = pcall(isfile, path)
    return ok and result
end

local function safeReadFile(path)
    if type(readfile) ~= "function" then
        return nil
    end
    local ok, result = pcall(readfile, path)
    return ok and result or nil
end

local function safeWriteFile(path, content)
    if type(writefile) ~= "function" then
        return false, "writefile not available"
    end
    local ok, result = pcall(writefile, path, content)
    return ok, result
end

local function createGui(name)
    local player = Players.LocalPlayer
    if not player then
        error("LocalPlayer is not available")
    end

    local playerGui = player:FindFirstChild("PlayerGui")
    if not playerGui then
        playerGui = Instance.new("PlayerGui")
        playerGui.Name = "PlayerGui"
        playerGui.Parent = player
    end

    local existing = playerGui:FindFirstChild(name)
    if existing then
        return existing
    end

    local gui = Instance.new("ScreenGui")
    gui.Name = name
    gui.IgnoreGuiInset = true
    gui.ResetOnSpawn = false
    gui.Parent = playerGui
    return gui
end

local function createLabel(text, size, parent)
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = size or UDim2.new(1, 0, 0, 24)
    label.Text = text or ""
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextScaled = true
    label.Font = Enum.Font.SourceSansSemibold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Center
    label.Parent = parent
    return label
end

local function createButton(title, size, parent)
    local button = Instance.new("TextButton")
    button.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    button.BorderSizePixel = 0
    button.Size = size or UDim2.new(1, 0, 0, 28)
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Text = title or "Button"
    button.Font = Enum.Font.SourceSansSemibold
    button.TextSize = 16
    button.Parent = parent
    return button
end

local function createSectionContainer(parent)
    local section = Instance.new("Frame")
    section.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    section.BorderSizePixel = 0
    section.Size = UDim2.new(1, 0, 0, 0)
    section.AutomaticSize = Enum.AutomaticSize.Y
    section.Parent = parent

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 6)
    layout.Parent = section

    return section
end

local function createControlFrame(title, parent)
    local frame = Instance.new("Frame")
    frame.BackgroundTransparency = 1
    frame.Size = UDim2.new(1, 0, 0, 34)
    frame.Parent = parent

    local name = createLabel(title, UDim2.new(0.5, 0, 1, 0), frame)
    name.Name = "Label"
    name.Size = UDim2.new(0.5, 0, 1, 0)
    name.TextXAlignment = Enum.TextXAlignment.Left

    return frame
end

local function createListFrame(parent)
    local frame = Instance.new("Frame")
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.BorderSizePixel = 0
    frame.Size = UDim2.new(1, 0, 0, 0)
    frame.AutomaticSize = Enum.AutomaticSize.Y
    frame.Visible = false
    frame.ClipsDescendants = true
    frame.Parent = parent

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 2)
    layout.Parent = frame

    return frame
end

local function createTabButton(title, size, parent)
    local button = Instance.new("TextButton")
    button.Name = title:gsub("%s+", "") .. "TabButton"
    button.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    button.BorderSizePixel = 0
    button.Size = size or UDim2.new(1, 0, 0, 32)
    button.Text = title
    button.Font = Enum.Font.SourceSansSemibold
    button.TextSize = 14
    button.TextColor3 = Color3.fromRGB(220, 220, 220)
    button.Parent = parent
    return button
end

local function seedWindow(config)
    local guiName = (config.Title or "LibraryUI") .. "Gui"
    local gui = createGui(guiName)

    local window = Instance.new("Frame")
    window.Name = "Window"
    window.Size = config.Size or Library.Options.DefaultWindowSize
    window.Position = config.Position or UDim2.new(0.5, 0, 0.5, 0)
    window.AnchorPoint = Vector2.new(0.5, 0.5)
    window.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    window.BorderSizePixel = 0
    window.Parent = gui

    local outer = Instance.new("Frame")
    outer.Name = "Border"
    outer.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
    outer.Size = UDim2.new(1, 1, 1, 1)
    outer.Position = UDim2.new(0, -1, 0, -1)
    outer.BorderSizePixel = 0
    outer.ZIndex = 0
    outer.Parent = window

    local titleLabel = createLabel(config.Title or "UI Window", UDim2.new(1, 0, 0, 30), window)
    titleLabel.Font = Enum.Font.SourceSansBold
    titleLabel.TextSize = 18
    titleLabel.Size = UDim2.new(1, 0, 0, 30)
    titleLabel.TextYAlignment = Enum.TextYAlignment.Center
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Text = "  " .. (config.Title or "UI Window")

    local tabBar = Instance.new("Frame")
    tabBar.Name = "TabBar"
    tabBar.BackgroundTransparency = 1
    tabBar.Size = UDim2.new(1, 0, 0, Library.Options.TabHeight)
    tabBar.Position = UDim2.new(0, 0, 0, 30)
    tabBar.Parent = window

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.FillDirection = Enum.FillDirection.Horizontal
    tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Padding = UDim.new(0, 2)
    tabLayout.Parent = tabBar

    local contentHolder = Instance.new("Frame")
    contentHolder.Name = "Content"
    contentHolder.BackgroundTransparency = 1
    contentHolder.Size = UDim2.new(1, 0, 1, -(30 + Library.Options.TabHeight))
    contentHolder.Position = UDim2.new(0, 0, 0, 30 + Library.Options.TabHeight)
    contentHolder.Parent = window

    local contentLayout = Instance.new("UIListLayout")
    contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
    contentLayout.Padding = UDim.new(0, 6)
    contentLayout.Parent = contentHolder

    local windowObject = {
        Gui = gui,
        Window = window,
        TabButtons = {},
        TabContents = {},
        SelectedIndex = 0,
    }

    function windowObject:Show()
        self.Window.Visible = true
    end

    function windowObject:Hide()
        self.Window.Visible = false
    end

    function windowObject:Toggle()
        self.Window.Visible = not self.Window.Visible
    end

    function windowObject:SelectTab(index)
        for i, content in ipairs(self.TabContents) do
            content.Frame.Visible = (i == index)
            self.TabButtons[i].BackgroundColor3 = (i == index and Color3.fromRGB(70, 70, 70) or Color3.fromRGB(40, 40, 40))
        end
        self.SelectedIndex = index
    end

    function windowObject:AddTab(props)
        local name = props.Title or "Tab"
        local button = createTabButton(name, UDim2.new(0, Library.Options.TabWidth, 1, 0), tabBar)

        local content = Instance.new("Frame")
        content.Name = name:gsub("%s+", "") .. "Content"
        content.BackgroundTransparency = 1
        content.Size = UDim2.new(1, 0, 1, 0)
        content.Visible = false
        content.Parent = contentHolder

        local contentLayout = Instance.new("UIListLayout")
        contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
        contentLayout.Padding = UDim.new(0, 8)
        contentLayout.Parent = content

        local tabObject = {
            Button = button,
            Content = content,
            Name = name,
        }

        function tabObject:AddSection(title)
            local section = createSectionContainer(self.Content)
            local titleLabel = createLabel(title, UDim2.new(1, 0, 0, 24), section)
            titleLabel.Font = Enum.Font.SourceSansBold
            titleLabel.TextSize = 16
            titleLabel.TextXAlignment = Enum.TextXAlignment.Left
            titleLabel.Text = title

            local sectionObject = {
                Frame = section,
            }

            function sectionObject:AddButton(props)
                local button = createButton(props.Title or "Button", UDim2.new(1, 0, 0, 28), section)
                if props.Tooltip then
                    button.Tooltip = props.Tooltip
                end
                button.MouseButton1Click:Connect(function()
                    if props.Callback then
                        props.Callback()
                    end
                end)
                return button
            end

            function sectionObject:AddToggle(id, props)
                local frame = createControlFrame(props.Title or id, section)
                local enabled = props.Default == true
                local button = createButton(enabled and "ON" or "OFF", UDim2.new(0.3, 0, 1, 0), frame)
                button.Position = UDim2.new(0.7, 0, 0, 0)
                button.TextScaled = true
                button.MouseButton1Click:Connect(function()
                    enabled = not enabled
                    button.Text = enabled and "ON" or "OFF"
                    if props.Callback then
                        props.Callback(enabled)
                    end
                end)
                return frame
            end

            function sectionObject:AddDropdown(id, props)
                local dropdownFrame = Instance.new("Frame")
                dropdownFrame.BackgroundTransparency = 1
                dropdownFrame.Size = UDim2.new(1, 0, 0, 30)
                dropdownFrame.Parent = section

                local label = createLabel(props.Title or id, UDim2.new(0.4, 0, 1, 0), dropdownFrame)
                label.Text = props.Title or id

                local button = createButton(tostring(props.Default or "Select"), UDim2.new(0.6, 0, 1, 0), dropdownFrame)
                button.Position = UDim2.new(0.4, 0, 0, 0)
                button.TextXAlignment = Enum.TextXAlignment.Left

                local list = createListFrame(section)
                local current = props.Default

                local function refreshLabel()
                    if props.Multi and type(current) == "table" then
                        button.Text = table.concat(current, ", ")
                    else
                        button.Text = tostring(current)
                    end
                end

                for _, value in ipairs(props.Values or {}) do
                    local item = createButton(tostring(value), UDim2.new(1, 0, 0, 26), list)
                    item.TextXAlignment = Enum.TextXAlignment.Left
                    item.MouseButton1Click:Connect(function()
                        if props.Multi then
                            current = current or {}
                            if type(current) ~= "table" then
                                current = {current}
                            end
                            local found = table.find(current, value)
                            if found then
                                table.remove(current, found)
                            else
                                table.insert(current, value)
                            end
                        else
                            current = value
                            list.Visible = false
                        end
                        refreshLabel()
                        if props.Callback then
                            props.Callback(current)
                        end
                    end)
                end

                button.MouseButton1Click:Connect(function()
                    list.Visible = not list.Visible
                end)

                refreshLabel()
                return dropdownFrame
            end

            function sectionObject:AddSlider(id, props)
                local sliderFrame = createControlFrame(props.Title or id, section)
                local minus = createButton("-", UDim2.new(0.15, 0, 1, 0), sliderFrame)
                minus.Position = UDim2.new(0.55, 0, 0, 0)
                local valueLabel = createLabel(tostring(props.Default or props.Minimum or 0), UDim2.new(0.15, 0, 1, 0), sliderFrame)
                valueLabel.Position = UDim2.new(0.7, 0, 0, 0)
                valueLabel.TextScaled = true
                valueLabel.TextXAlignment = Enum.TextXAlignment.Center
                local plus = createButton("+", UDim2.new(0.15, 0, 1, 0), sliderFrame)
                plus.Position = UDim2.new(0.85, 0, 0, 0)

                local minimum = props.Minimum or 0
                local maximum = props.Maximum or 100
                local step = props.Rounding or 1
                local current = props.Default or minimum

                local function updateValue(newValue)
                    current = math.clamp(newValue, minimum, maximum)
                    valueLabel.Text = tostring(current)
                    if props.Callback then
                        props.Callback(current)
                    end
                end

                minus.MouseButton1Click:Connect(function()
                    updateValue(current - step)
                end)
                plus.MouseButton1Click:Connect(function()
                    updateValue(current + step)
                end)

                return sliderFrame
            end

            function sectionObject:AddInput(id, props)
                local inputFrame = createControlFrame(props.Title or id, section)
                local textBox = Instance.new("TextBox")
                textBox.Size = UDim2.new(0.6, 0, 1, 0)
                textBox.Position = UDim2.new(0.4, 0, 0, 0)
                textBox.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
                textBox.BorderSizePixel = 0
                textBox.Text = props.Default or ""
                textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
                textBox.PlaceholderText = props.Placeholder or ""
                textBox.Font = Enum.Font.SourceSans
                textBox.TextSize = 16
                textBox.ClearTextOnFocus = false
                textBox.Parent = inputFrame

                textBox.FocusLost:Connect(function()
                    if props.Callback then
                        props.Callback(textBox.Text)
                    end
                end)
                return inputFrame
            end

            function sectionObject:AddParagraph(props)
                local paragraph = Instance.new("TextLabel")
                paragraph.BackgroundTransparency = 1
                paragraph.Size = UDim2.new(1, 0, 0, 42)
                paragraph.Text = props.Text or props.Title or ""
                paragraph.TextWrapped = true
                paragraph.TextColor3 = Color3.fromRGB(235, 235, 235)
                paragraph.Font = Enum.Font.SourceSans
                paragraph.TextSize = 14
                paragraph.TextXAlignment = Enum.TextXAlignment.Left
                paragraph.TextYAlignment = Enum.TextYAlignment.Top
                paragraph.Parent = section
                return paragraph
            end

            return sectionObject
        end

        table.insert(self.TabButtons, button)
        table.insert(self.TabContents, { Frame = content })

        button.MouseButton1Click:Connect(function()
            self:SelectTab(#self.TabButtons)
        end)

        return setmetatable(tabObject, {
            __index = function(table, key)
                return rawget(table, key)
            end,
        })
    end

    return windowObject
end

function Library:CreateWindow(config)
    self.Config = config and config.Config or {}
    self.CurrentWindow = seedWindow(config or {})
    self.SaveManager:SetLibrary(self)
    self.InterfaceManager:SetLibrary(self)
    return self.CurrentWindow
end

function Library:Notify(props)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = props.Title or "Notification",
            Text = props.Content or props.Text or "",
            Duration = props.Duration or 5,
        })
    end)
end

local SaveManager = {}
SaveManager.Folder = "LibraryConfigs"
SaveManager.FileName = "config.json"
SaveManager.AutoloadFile = "autoload.json"
SaveManager.IgnoreIndexes = {}
SaveManager.IgnoreTheme = false
SaveManager.AutoloadEnabled = false
SaveManager.Library = nil

function SaveManager:SetLibrary(lib)
    self.Library = lib
end

function SaveManager:SetIgnoreIndexes(indexes)
    self.IgnoreIndexes = indexes or {}
end

function SaveManager:IgnoreThemeSettings()
    self.IgnoreTheme = true
end

function SaveManager:SetFolder(folder)
    self.Folder = folder
end

function SaveManager:SetFileName(fileName)
    self.FileName = fileName
end

function SaveManager:SetAutoloadFile(fileName)
    self.AutoloadFile = fileName
end

function SaveManager:GetConfigPath(fileName)
    local name = fileName or self.FileName
    return string.format("%s/%s", self.Folder, name)
end

function SaveManager:GetConfig()
    local config = {}
    if self.Library and self.Library.Options then
        for key, value in pairs(self.Library.Options) do
            if not (self.IgnoreTheme and (key == "Theme" or key == "Acrylic")) then
                config[key] = value
            end
        end
    end
    if self.Library and self.Library.Config then
        for key, value in pairs(self.Library.Config) do
            config[key] = value
        end
    end
    return config
end

function SaveManager:ApplyConfig(config)
    if type(config) ~= "table" then
        return false
    end
    if self.Library then
        if self.Library.Options then
            for key, value in pairs(config) do
                if not (self.IgnoreTheme and (key == "Theme" or key == "Acrylic")) then
                    self.Library.Options[key] = value
                end
            end
        end
        if self.Library.Config then
            for key, value in pairs(config) do
                self.Library.Config[key] = value
            end
        end
    end
    return true
end

function SaveManager:Serialize(config)
    return HttpService:JSONEncode(config)
end

function SaveManager:Deserialize(text)
    local ok, result = pcall(function()
        return HttpService:JSONDecode(text)
    end)
    return ok and result or nil
end

function SaveManager:SaveConfig(fileName)
    local path = self:GetConfigPath(fileName)
    local config = self:GetConfig()
    local json = self:Serialize(config)
    local ok, err = safeWriteFile(path, json)
    return ok, err
end

function SaveManager:LoadConfig(fileName)
    local path = self:GetConfigPath(fileName)
    if not safeIsFile(path) then
        return nil, "Config file not found: " .. path
    end
    local text = safeReadFile(path)
    if not text then
        return nil, "Unable to read config file"
    end
    local config = self:Deserialize(text)
    if not config then
        return nil, "Invalid config format"
    end
    self:ApplyConfig(config)
    return config
end

function SaveManager:LoadAutoloadConfig()
    return self:LoadConfig(self.AutoloadFile)
end

function SaveManager:BuildConfigSection(tab)
    if not tab or not tab.AddSection then
        return
    end

    local section = tab:AddSection("Save Manager")
    section:AddParagraph({ Text = "Use this section to save and load settings to local config files." })

    local fileName = self.FileName
    local input = section:AddInput("ConfigFile", {
        Title = "Config File",
        Default = fileName,
        Placeholder = "myconfig.json",
        Callback = function(value)
            if value and value ~= "" then
                self.FileName = value
                fileName = value
            end
        end,
    })

    section:AddButton({
        Title = "Save Config",
        Callback = function()
            local ok, err = self:SaveConfig(fileName)
            if ok then
                self.Library:Notify({ Title = "Save Config", Content = "Saved " .. fileName, Duration = 4 })
            else
                self.Library:Notify({ Title = "Save Config", Content = "Save failed: " .. tostring(err), Duration = 6 })
            end
        end,
    })

    section:AddButton({
        Title = "Load Config",
        Callback = function()
            local config, err = self:LoadConfig(fileName)
            if config then
                self.Library:Notify({ Title = "Load Config", Content = "Loaded " .. fileName, Duration = 4 })
            else
                self.Library:Notify({ Title = "Load Config", Content = "Load failed: " .. tostring(err), Duration = 6 })
            end
        end,
    })

    section:AddToggle("Autoload", {
        Title = "Autoload on Start",
        Default = self.AutoloadEnabled,
        Callback = function(value)
            self.AutoloadEnabled = value
        end,
    })

    section:AddButton({
        Title = "Save Autoload Config",
        Callback = function()
            local ok, err = self:SaveConfig(self.AutoloadFile)
            if ok then
                self.Library:Notify({ Title = "Autoload", Content = "Autoload config saved", Duration = 4 })
            else
                self.Library:Notify({ Title = "Autoload", Content = "Save failed: " .. tostring(err), Duration = 6 })
            end
        end,
    })

    section:AddButton({
        Title = "Load Autoload Config",
        Callback = function()
            local config, err = self:LoadAutoloadConfig()
            if config then
                self.Library:Notify({ Title = "Autoload", Content = "Autoload config loaded", Duration = 4 })
            else
                self.Library:Notify({ Title = "Autoload", Content = "Load failed: " .. tostring(err), Duration = 6 })
            end
        end,
    })

    return section
end

local InterfaceManager = {}
InterfaceManager.Library = nil
InterfaceManager.Folder = nil

function InterfaceManager:SetLibrary(lib)
    self.Library = lib
end

function InterfaceManager:SetFolder(folder)
    self.Folder = folder
end

function InterfaceManager:BuildInterfaceSection(tab)
    if not tab or not tab.AddSection then
        return
    end

    local section = tab:AddSection("Interface Manager")
    section:AddParagraph({ Text = "Manage the library window interface and quick visibility actions." })

    section:AddButton({
        Title = "Toggle Window",
        Callback = function()
            if self.Library and self.Library.CurrentWindow then
                self.Library.CurrentWindow:Toggle()
            end
        end,
    })

    section:AddButton({
        Title = "Show Window",
        Callback = function()
            if self.Library and self.Library.CurrentWindow then
                self.Library.CurrentWindow:Show()
            end
        end,
    })

    section:AddButton({
        Title = "Hide Window",
        Callback = function()
            if self.Library and self.Library.CurrentWindow then
                self.Library.CurrentWindow:Hide()
            end
        end,
    })

    return section
end

Library.SaveManager = SaveManager
Library.InterfaceManager = InterfaceManager

return Library
