                    Padding = UDim.new(0, 2)
                })
                
                local function UpdateDropdownList()
                    for _, child in pairs(ListScrolling:GetChildren()) do
                        if child:IsA("TextButton") then
                            child:Destroy()
                        end
                    end
                    
                    for _, option in ipairs(DropdownOptions) do
                        local OptionBtn = CreateInstance("TextButton", {
                            Name = tostring(option),
                            Parent = ListScrolling,
                            BackgroundColor3 = CurrentTheme.DarkOutline,
                            BorderSizePixel = 0,
                            Size = UDim2.new(1, 0, 0, 26),
                            Font = Enum.Font.Gotham,
                            Text = tostring(option),
                            TextColor3 = CurrentTheme.Text,
                            TextSize = 12,
                            ZIndex = 10,
                            AutoButtonColor = false
                        })
                        Corner(OptionBtn, 4)
                        
                        OptionBtn.MouseEnter:Connect(function()
                            TweenObject(OptionBtn, {BackgroundColor3 = CurrentTheme.Accent}, 0.2)
                        end)
                        
                        OptionBtn.MouseLeave:Connect(function()
                            TweenObject(OptionBtn, {BackgroundColor3 = CurrentTheme.DarkOutline}, 0.2)
                        end)
                        
                        OptionBtn.MouseButton1Click:Connect(function()
                            Selected = option
                            DropdownButton.Text = tostring(option)
                            IsOpen = false
                            DropdownList.Visible = false
                            TweenObject(DropdownIcon, {Rotation = 0}, DebounceTime)
                            if callback then callback(option) end
                        end)
                    end
                    
                    local listHeight = math.min(#DropdownOptions * 28, 150)
                    ListScrolling.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y + 5)
                    DropdownList.Size = UDim2.new(1, 0, 0, listHeight + 10)
                end
                
                UpdateDropdownList()
                
                DropdownButton.MouseButton1Click:Connect(function()
                    IsOpen = not IsOpen
                    DropdownList.Visible = IsOpen
                    TweenObject(DropdownIcon, {Rotation = IsOpen and 180 or 0}, DebounceTime)
                end)
                
                function DropdownObj:UpdateDropdown(newOptions)
                    DropdownOptions = newOptions or {}
                    Selected = nil
                    DropdownButton.Text = "Select..."
                    UpdateDropdownList()
                end
                
                return DropdownObj
            end
            
