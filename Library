local function seedWindow(config)
	local windowTitle = config.Title or "Roblox UI Library"
	local windowSize = config.Size or Library.DefaultWindowSize

	local gui = createGui(windowTitle:gsub("%s+", ""))
	
	local windowFrame = Instance.new("Frame")
	windowFrame.Size = windowSize
	windowFrame.Position = UDim2.new(0.5, -windowSize.X.Offset/2, 0.5, -windowSize.Y.Offset/2)
	windowFrame.BackgroundColor3 = Color3.fromRGB(15, 15, 18)
	windowFrame.Active = true
	windowFrame.Draggable = true -- Basic dragging enabling
	windowFrame.Parent = gui

	local stroke = Instance.new("UIStroke")
	stroke.Color = Color3.fromRGB(45, 45, 50)
	stroke.Parent = windowFrame

	local corner = Instance.new("UICorner")
	corner.CornerRadius = UDim.new(0, 6)
	corner.Parent = windowFrame

	-- Title
	local titleLabel = createLabel(windowTitle, UDim2.new(1, -20, 0, 30), windowFrame)
	titleLabel.Position = UDim2.new(0, 10, 0, 0)
	titleLabel.Font = Enum.Font.SourceSansBold

	-- Tab Bar Container
	local tabBar = Instance.new("ScrollingFrame")
	tabBar.Size = UDim2.new(0, Library.TabWidth, 1, -40)
	tabBar.Position = UDim2.new(0, 10, 0, 35)
	tabBar.BackgroundTransparency = 1
	tabBar.ScrollBarThickness = 2
	tabBar.CanvasSize = UDim2.new(0, 0, 0, 0)
	tabBar.Parent = windowFrame

	local tabLayout = Instance.new("UIListLayout")
	tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
	tabLayout.Padding = UDim.new(0, 4)
	tabLayout.Parent = tabBar

	tabLayout.GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		tabBar.CanvasSize = UDim2.new(0, 0, 0, tabLayout.AbsoluteContentSize.Y)
	end)

	-- Content Holder
	local contentHolder = Instance.new("Frame")
	contentHolder.Size = UDim2.new(1, -(Library.TabWidth + 30), 1, -40)
	contentHolder.Position = UDim2.new(0, Library.TabWidth + 20, 0, 35)
	contentHolder.BackgroundTransparency = 1
	contentHolder.Parent = windowFrame

	-- Minimize key toggle
	local minCon = UserInputService.InputBegins:Connect(function(input, processed)
		if not processed and input.KeyCode == Library.MinimizeKey then
			windowFrame.Visible = not windowFrame.Visible
		end
	end)
	table.insert(Library.Connections, minCon)

	return {
		Gui = gui,
		Window = windowFrame,
		TabButtons = {},
		TabContents = {},
		SelectedIndex = 1,
		TabBar = tabBar,
		ContentHolder = contentHolder
	}
end

function Library:CreateWindow(config)
	config = config or {}
	local windowObj = seedWindow(config)
	
	function windowObj:SelectTab(index)
		self.SelectedIndex = index
		for i, content in ipairs(self.TabContents) do
			content.Visible = (i == index)
			if self.TabButtons[i] then
				self.TabButtons[i].BackgroundColor3 = (i == index) and Color3.fromRGB(40, 40, 48) or Color3.fromRGB(20, 20, 25)
			end
		end
	end

	function windowObj:AddTab(props)
		local tabTitle = props.Title or "Tab"
		local tabIndex = #self.TabButtons + 1

		local tabBtn = createTabButton(tabTitle, UDim2.new(1, 0, 0, 30), self.TabBar)
		table.insert(self.TabButtons, tabBtn)

		local contentFrame = Instance.new("ScrollingFrame")
		contentFrame.Size = UDim2.new(1, 0, 1, 0)
		contentFrame.BackgroundTransparency = 1
		contentFrame.ScrollBarThickness = 4
		contentFrame.Visible = false
		contentFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
		contentFrame.Parent = self.ContentHolder
		table.insert(self.TabContents, contentFrame)

		local contentLayout = Instance.new("UIListLayout")
		contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
		contentLayout.Padding = UDim.new(0, 12)
		contentLayout.Parent = contentFrame

		contentLayout.GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
			contentFrame.CanvasSize = UDim2.new(0, 0, 0, contentLayout.AbsoluteContentSize.Y)
		end)

		tabBtn.MouseButton1Click:Connect(function()
			self:SelectTab(tabIndex)
		end)

		if tabIndex == 1 then
			self:SelectTab(1)
		end

		local tabObject = { Frame = contentFrame }

		function tabObject:AddSection(title)
			local sectionFrame = Instance.new("Frame")
			sectionFrame.Size = UDim2.new(1, -10, 0, 0)
			sectionFrame.BackgroundColor3 = Color3.fromRGB(22, 22, 26)
			sectionFrame.Parent = self.Frame

			local stroke = Instance.new("UIStroke")
			stroke.Color = Color3.fromRGB(35, 35, 40)
			stroke.Parent = sectionFrame

			local corner = Instance.new("UICorner")
			corner.CornerRadius = UDim.new(0, 4)
			corner.Parent = sectionFrame

			local sectionTitle = createLabel("  " .. title, UDim2.new(1, 0, 0, 24), sectionFrame)
			sectionTitle.Font = Enum.Font.SourceSansBold

			local container = createSectionContainer(sectionFrame)
			container.Position = UDim2.new(0, 8, 0, 28)
			container.Size = UDim2.new(1, -16, 0, 0)

			container.ChildAdded:Connect(function()
				task.wait()
				sectionFrame.Size = UDim2.new(1, -10, 0, container.Size.Y.Offset + 36)
			end)
			container:GetPropertyChangedSignal("Size"):Connect(function()
				sectionFrame.Size = UDim2.new(1, -10, 0, container.Size.Y.Offset + 36)
			end)

			local sectionObject = { Container = container }

			function sectionObject:AddButton(btnProps)
				local btn = createButton(btnProps.Title or "Button", UDim2.new(1, 0, 0, 30), self.Container)
				btn.MouseButton1Click:Connect(function()
					if btnProps.Callback then task.spawn(btnProps.Callback) end
				end)
				return btn
			end

			function sectionObject:AddToggle(id, tglProps)
				local ctrl = createControlFrame(tglProps.Title or "Toggle", self.Container)
				local state = tglProps.Default or false

				local triggerBtn = Instance.new("TextButton")
				triggerBtn.Size = UDim2.new(0, 40, 0, 20)
				triggerBtn.Position = UDim2.new(1, -40, 0.5, -10)
				triggerBtn.BackgroundColor3 = state and Color3.fromRGB(65, 185, 85) or Color3.fromRGB(55, 55, 60)
				triggerBtn.Text = state and "ON" or "OFF"
				triggerBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
				triggerBtn.Font = Enum.Font.SourceSansBold
				triggerBtn.TextSize = 12
				triggerBtn.Parent = ctrl

				local corner = Instance.new("UICorner")
				corner.CornerRadius = UDim.new(0, 10)
				corner.Parent = triggerBtn

				local function setState(v)
					state = v
					triggerBtn.BackgroundColor3 = state and Color3.fromRGB(65, 185, 85) or Color3.fromRGB(55, 55, 60)
					triggerBtn.Text = state and "ON" or "OFF"
					if tglProps.Callback then task.spawn(tglProps.Callback, state) end
				end

				triggerBtn.MouseButton1Click:Connect(function()
					setState(not state)
				end)

				Library.Options[id] = {
					Type = "Toggle",
					Value = state,
					Set = function(selfOpt, v) setState(v) end
				}

				-- Run init callback without explicit events trigger requirement based on standard logic
				if tglProps.Default and tglProps.Callback then
					task.spawn(tglProps.Callback, state)
				end

				return Library.Options[id]
			end

			function sectionObject:AddDropdown(id, dropProps)
				local mainContainer = Instance.new("Frame")
				mainContainer.Size = UDim2.new(1, 0, 0, 32)
				mainContainer.BackgroundTransparency = 1
				mainContainer.Parent = self.Container

				local ctrl = createControlFrame(dropProps.Title or "Dropdown", mainContainer)
				
				local triggerBtn = createButton(tostring(dropProps.Default or "Select..."), UDim2.new(0.5, 0, 0, 24), ctrl)
				triggerBtn.Position = UDim2.new(0.5, 0, 0.5, -12)

				local listFrame = createListFrame(mainContainer)
				listFrame.Position = UDim2.new(0.5, 0, 0, 30)
				listFrame.ZIndex = 5

				local multi = dropProps.Multi or false
				local selectedValues = multi and (type(dropProps.Default) == "table" and dropProps.Default or {}) or dropProps.Default

				local layout = mainContainer.Parent:FindFirstChildOfClass("UIListLayout")

				local function updateLabel()
					if multi then
						local count = 0
						for _ in pairs(selectedValues) do count = count + 1 end
						triggerBtn.Text = count > 0 and (count .. " Selected") or "None"
					else
						triggerBtn.Text = tostring(selectedValues or "Select...")
					end
				end

				local function processSelection(val)
					if multi then
						if selectedValues[val] then
							selectedValues[val] = nil
						else
							selectedValues[val] = true
						end
						updateLabel()
						if dropProps.Callback then task.spawn(dropProps.Callback, selectedValues) end
					else
						selectedValues = val
						updateLabel()
						listFrame.Visible = false
						mainContainer.Size = UDim2.new(1, 0, 0, 32)
						if dropProps.Callback then task.spawn(dropProps.Callback, selectedValues) end
					end
				end

				local function populate(values)
					for _, child in ipairs(listFrame:GetChildren()) do
						if child:IsA("TextButton") then child:Destroy() end
					end
					for _, val in ipairs(values) do
						local optBtn = createButton(tostring(val), UDim2.new(1, 0, 0, 24), listFrame)
						optBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 35)
						optBtn.ZIndex = 6
						optBtn.MouseButton1Click:Connect(function()
							processSelection(val)
						end)
					end
				end

				if dropProps.Values then populate(dropProps.Values) end

				triggerBtn.MouseButton1Click:Connect(function()
					listFrame.Visible = not listFrame.Visible
					mainContainer.Size = listFrame.Visible and UDim2.new(1, 0, 0, 32 + listFrame.Size.Y.Offset) or UDim2.new(1, 0, 0, 32)
				end)

				listFrame:GetPropertyChangedSignal("Size"):Connect(function()
					if listFrame.Visible then
						mainContainer.Size = UDim2.new(1, 0, 0, 32 + listFrame.Size.Y.Offset)
					end
				end)

				updateLabel()

				Library.Options[id] = {
					Type = "Dropdown",
					Value = selectedValues,
					Set = function(selfOpt, v)
						selectedValues = v
						updateLabel()
						if dropProps.Callback then task.spawn(dropProps.Callback, selectedValues) end
					end,
					Refresh = function(selfOpt, newValues)
						populate(newValues)
					end
				}

				if dropProps.Default and dropProps.Callback then
					task.spawn(dropProps.Callback, selectedValues)
				end

				return Library.Options[id]
			end

			function sectionObject:AddSlider(id, sldProps)
				local ctrl = Instance.new("Frame")
				ctrl.Size = UDim2.new(1, 0, 0, 45)
				ctrl.BackgroundTransparency = 1
				ctrl.Parent = self.Container

				local title = createLabel(sldProps.Title or "Slider", UDim2.new(0.6, 0, 0, 20), ctrl)
				local valueDisplay = createLabel(tostring(sldProps.Default or sldProps.Minimum or 0), UDim2.new(0.4, 0, 0, 20), ctrl)
				valueDisplay.Position = UDim2.new(0.6, 0, 0, 0)
				valueDisplay.TextXAlignment = Enum.TextXAlignment.Right

				local bar = Instance.new("TextButton")
				bar.Size = UDim2.new(1, 0, 0, 10)
				bar.Position = UDim2.new(0, 0, 0, 25)
				bar.BackgroundColor3 = Color3.fromRGB(40, 40, 45)
				bar.Text = ""
				bar.Parent = ctrl

				local fill = Instance.new("Frame")
				fill.Size = UDim2.new(0, 0, 1, 0)
				fill.BackgroundColor3 = Color3.fromRGB(75, 120, 210)
				fill.Parent = bar

				local corner1 = Instance.new("UICorner")
				corner1.CornerRadius = UDim.new(1, 0)
				corner1.Parent = bar

				local corner2 = corner1:Clone()
				corner2.Parent = fill

				local min = sldProps.Minimum or 0
				local max = sldProps.Maximum or 100
				local round = sldProps.Rounding or 0
				local currentValue = sldProps.Default or min

				local function setSlider(val)
					val = math.clamp(val, min, max)
					local factor = 10 ^ round
					val = math.round(val * factor) / factor

					currentValue = val
					valueDisplay.Text = tostring(val)
					
					local pct = (val - min) / (max - min)
					fill.Size = UDim2.new(pct, 0, 1, 0)

					Library.Options[id].Value = val
					if sldProps.Callback then task.spawn(sldProps.Callback, val) end
				end

				local dragging = false
				bar.InputBegins:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true end
				end)
				
				local con1 = UserInputService.InputEnded:Connect(function(input)
					if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
				end)
				table.insert(Library.Connections, con1)

				local con2 = UserInputService.InputChanged:Connect(function(input)
					if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
						local mousePos = UserInputService:GetMouseLocation().X
						local barPos = bar.AbsolutePosition.X
						local barSize = bar.AbsoluteSize.X
						local pct = math.clamp((mousePos - barPos) / barSize, 0, 1)
						setSlider(min + (max - min) * pct)
					end
				end)
				table.insert(Library.Connections, con2)

				Library.Options[id] = {
					Type = "Slider",
					Value = currentValue,
					Set = function(selfOpt, v) setSlider(v) end
				}

				setSlider(currentValue)
				return Library.Options[id]
			end

			function sectionObject:AddInput(id, inpProps)
				local ctrl = createControlFrame(inpProps.Title or "Input", self.Container)
				
				local textBox = Instance.new("TextBox")
				textBox.Size = UDim2.new(0.5, 0, 0, 24)
				textBox.Position = UDim2.new(0.5, 0, 0.5, -12)
				textBox.BackgroundColor3 = Color3.fromRGB(25, 25, 30)
				textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
				textBox.Font = Enum.Font.SourceSansSemiBold
				textBox.TextSize = 14
				textBox.PlaceholderText = inpProps.Placeholder or ""
				textBox.Text = inpProps.Default or ""
				textBox.ClearTextOnFocus = false
				textBox.Parent = ctrl

				local corner = Instance.new("UICorner")
				corner.CornerRadius = UDim.new(0, 4)
				corner.Parent = textBox

				textBox.FocusLost:Connect(function()
					Library.Options[id].Value = textBox.Text
					if inpProps.Callback then task.spawn(inpProps.Callback, textBox.Text) end
				end)

				Library.Options[id] = {
					Type = "Input",
					Value = textBox.Text,
					Set = function(selfOpt, v)
						textBox.Text = tostring(v)
						selfOpt.Value = textBox.Text
						if inpProps.Callback then task.spawn(inpProps.Callback, textBox.Text) end
					end
				}

				if inpProps.Default and inpProps.Callback and inpProps.Default ~= "" then
					task.spawn(inpProps.Callback, inpProps.Default)
				end

				return Library.Options[id]
			end

			function sectionObject:AddParagraph(pProps)
				local container = Instance.new("Frame")
				container.Size = UDim2.new(1, 0, 0, 0)
				container.BackgroundTransparency = 1
				container.Parent = self.Container

				local title = createLabel(pProps.Title or "Paragraph", UDim2.new(1, 0, 0, 20), container)
				title.Font = Enum.Font.SourceSansBold

				local content = createLabel(pProps.Content or pProps.Text or "", UDim2.new(1, 0, 0, 0), container)
				content.Position = UDim2.new(0, 0, 0, 20)
				content.TextWrapped = true
				content.TextColor3 = Color3.fromRGB(180, 180, 185)
				content.TextYAlignment = Enum.TextYAlignment.Top

				-- Adjust runtime heights based on Text bounds
				local function adjust()
					content.Size = UDim2.new(1, 0, 0, content.TextBounds.Y + 5)
					container.Size = UDim2.new(1, 0, 0, 20 + content.Size.Y.Offset)
				end
				content:GetPropertyChangedSignal("TextBounds"):Connect(adjust)
				adjust()

				return container
			end

			return sectionObject
		end

		return tabObject
	end

	-- Initialize options theme settings handling
	Library.SaveManager:SetLibrary(Library)
	Library.InterfaceManager:SetLibrary(Library)

	return windowObj
end

