local Library = {
	Options = {}, -- Stores active component objects for saving/loading
	Theme = "Dark",
	Acrylic = true,
	MinimizeKey = Enum.KeyCode.RightShift,
	TabWidth = 140,
	TabHeight = 80,
	DefaultWindowSize = UDim2.new(0, 650, 0, 350),
	Connections = {}
}

