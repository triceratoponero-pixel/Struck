                })
                
                local SliderBackground = CreateInstance("Frame", {
                    Name = "Background",
                    Parent = SliderFrame,
                    BackgroundColor3 = CurrentTheme.DarkOutline,
                    BorderSizePixel = 0,
                    Position = UDim2.new(0, 0, 0, 30),
                    Size = UDim2.new(1, 0, 0, 6)
                })
                Corner(SliderBackground, 3)
                
                local SliderFill = CreateInstance("Frame", {
                    Name = "Fill",
                    Parent = SliderBackground,
                    BackgroundColor3 = SliderColor,
                    BorderSizePixel = 0,
                    Size = UDim2.new((DefaultValue - MinValue) / (MaxValue - MinValue), 0, 1, 0)
                })
                Corner(SliderFill, 3)
                
                local SliderKnob = CreateInstance("Frame", {
                    Name = "Knob",
                    Parent = SliderBackground,
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    BorderSizePixel = 0,
                    Position = UDim2.new((DefaultValue - MinValue) / (MaxValue - MinValue), -6, 0.5, -6),
                    Size = UDim2.new(0, 12, 0, 12),
                    AnchorPoint = Vector2.new(0, 0)
                })
                Corner(SliderKnob, 6)
                
                local Dragging = false
                
                local function UpdateSlider(input)
                    local pos = math.clamp((input.Position.X - SliderBackground.AbsolutePosition.X) / SliderBackground.AbsoluteSize.X, 0, 1)
                    local value = math.floor(MinValue + (pos * (MaxValue - MinValue)))
                    ValueLabel.Text = tostring(value)
                    SliderFill.Size = UDim2.new(pos, 0, 1, 0)
                    SliderKnob.Position = UDim2.new(pos, -6, 0.5, -6)
                    if callback then callback(value) end
                end
                
                SliderBackground.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        Dragging = true
                        UpdateSlider(input)
                    end
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if Dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        UpdateSlider(input)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        Dragging = false
                    end
                end)
                
                return SliderObj
            end
            
