local Library = {}

Library.Options = {
    Theme = "Dark",
    Acrylic = true,
    MinimizeKey = Enum.KeyCode.RightShift,
    TabWidth = 140,
    TabHeight = 80,
    DefaultWindowSize = UDim2.new(0, 650, 0, 350),
}

local TweenService = game:GetService("TweenService")

local function tween(target, properties, time)
    local info = TweenInfo.new(time or 0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    local tweenObject = TweenService:Create(target, info, properties)
    tweenObject:Play()
    return tweenObject
end

local function addUICorner(instance, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 8)
    corner.Parent = instance
    return corner
end

local function addUIStroke(instance, color, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Color = color or Color3.fromRGB(70, 70, 70)
    stroke.Thickness = thickness or 1
    stroke.Transparency = 0.75
    stroke.Parent = instance
    return stroke
end

local function createGui(name)
    local player = game:GetService("Players").LocalPlayer
    local playerGui = player and player:FindFirstChild("PlayerGui")
    if not playerGui then
        playerGui = Instance.new("ScreenGui")
        playerGui.Name = name
        playerGui.Parent = player
        return playerGui
    end

    local existing = playerGui:FindFirstChild(name)
    if existing then
        return existing
    end

    local gui = Instance.new("ScreenGui")
    gui.Name = name
    gui.IgnoreGuiInset = true
    gui.ResetOnSpawn = false
    gui.Parent = playerGui
    return gui
end

local function createLabel(text, size, parent)
    local label = Instance.new("TextLabel")
    label.BackgroundTransparency = 1
    label.Size = size or UDim2.new(1, 0, 0, 24)
    label.Text = text or ""
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextScaled = true
    label.Font = Enum.Font.SourceSansSemibold
    label.TextXAlignment = Enum.TextXAlignment.Left
    label.TextYAlignment = Enum.TextYAlignment.Center
    label.Parent = parent
    return label
end

local function createButton(title, size, parent)
    local button = Instance.new("TextButton")
    button.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    button.BorderSizePixel = 0
    button.Size = size or UDim2.new(1, 0, 0, 28)
    button.TextColor3 = Color3.fromRGB(255, 255, 255)
    button.Text = title or "Button"
    button.Font = Enum.Font.SourceSansSemibold
    button.TextSize = 14
    button.AutoButtonColor = false
    button.ClipsDescendants = true
    button.Parent = parent

    addUICorner(button, 8)
    addUIStroke(button, Color3.fromRGB(80, 80, 80), 1)

    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 50, 50)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(40, 40, 40)),
    }
    gradient.Rotation = 90
    gradient.Parent = button

    return button
end

local function createSectionContainer(parent)
    local section = Instance.new("Frame")
    section.BackgroundColor3 = Color3.fromRGB(38, 38, 38)
    section.BorderSizePixel = 0
    section.Size = UDim2.new(1, 0, 0, 0)
    section.AutomaticSize = Enum.AutomaticSize.Y
    section.Parent = parent

    addUICorner(section, 12)
    addUIStroke(section, Color3.fromRGB(70, 70, 70), 1)

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 8)
    layout.Parent = section

    return section
end

local function createControlFrame(title, parent)
    local frame = Instance.new("Frame")
    frame.BackgroundTransparency = 1
    frame.Size = UDim2.new(1, 0, 0, 34)
    frame.Parent = parent

    local name = createLabel(title, UDim2.new(0.5, 0, 1, 0), frame)
    name.Name = "Label"
    name.Size = UDim2.new(0.5, 0, 1, 0)
    name.TextXAlignment = Enum.TextXAlignment.Left

    return frame
end

local function createListFrame(parent)
    local frame = Instance.new("Frame")
    frame.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    frame.BorderSizePixel = 0
    frame.Size = UDim2.new(1, 0, 0, 0)
    frame.AutomaticSize = Enum.AutomaticSize.Y
    frame.Visible = false
    frame.ClipsDescendants = true
    frame.Parent = parent

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 2)
    layout.Parent = frame

    return frame
end

local function createTabButton(title, icon, iconSize, size, parent)
    local iconMap = {
        home = "🏠",
        bot = "🤖",
        swords = "⚔️",
        book = "📘",
        sprout = "🌿",
        biohazard = "☣️",
        star = "⭐",
        settings = "⚙️",
    }

    local function isImageAsset(value)
        return type(value) == "string" and (value:match("^rbxassetid://") or value:match("^https?://") or value:match("^asset://"))
    end

    local button = Instance.new("TextButton")
    button.Name = title:gsub("%s+", "") .. "TabButton"
    button.BackgroundColor3 = Color3.fromRGB(37, 37, 37)
    button.BorderSizePixel = 0
    button.Size = size or UDim2.new(1, 0, 0, 36)
    button.Text = ""
    button.AutoButtonColor = false
    button.ClipsDescendants = true
    button.Parent = parent

    addUICorner(button, 12)
    addUIStroke(button, Color3.fromRGB(70, 70, 70), 1)

    local gradient = Instance.new("UIGradient")
    gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(42, 42, 42)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(33, 33, 33)),
    }
    gradient.Rotation = 90
    gradient.Parent = button

    local padding = Instance.new("UIPadding")
    padding.PaddingLeft = UDim.new(0, 12)
    padding.PaddingRight = UDim.new(0, 12)
    padding.PaddingTop = UDim.new(0, 8)
    padding.PaddingBottom = UDim.new(0, 8)
    padding.Parent = button

    local layout = Instance.new("UIListLayout")
    layout.FillDirection = Enum.FillDirection.Horizontal
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.Padding = UDim.new(0, 10)
    layout.Parent = button

    local iconSizeValue = iconSize or Vector2.new(24, 24)
    if icon then
        local iconLabel = Instance.new("TextLabel")
        iconLabel.Name = "IconLabel"
        iconLabel.BackgroundTransparency = 1
        iconLabel.Size = UDim2.new(0, iconSizeValue.X, 0, iconSizeValue.Y)
        iconLabel.Font = Enum.Font.SourceSansBold
        iconLabel.TextSize = 18
        iconLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
        iconLabel.Text = iconMap[string.lower(icon)] or ""
        iconLabel.TextXAlignment = Enum.TextXAlignment.Center
        iconLabel.TextYAlignment = Enum.TextYAlignment.Center
        iconLabel.Parent = button

        if iconLabel.Text == "" and isImageAsset(icon) then
            local image = Instance.new("ImageLabel")
            image.Name = "IconImage"
            image.BackgroundTransparency = 1
            image.Size = UDim2.new(1, 0, 1, 0)
            image.Image = icon
            image.ScaleType = Enum.ScaleType.Fit
            image.Parent = iconLabel
        end
    end

    local titleLabel = Instance.new("TextLabel")
    titleLabel.Name = "Title"
    titleLabel.BackgroundTransparency = 1
    titleLabel.Size = UDim2.new(1, 0, 1, 0)
    titleLabel.Text = title
    titleLabel.TextColor3 = Color3.fromRGB(220, 220, 220)
    titleLabel.TextSize = 14
    titleLabel.TextScaled = false
    titleLabel.TextWrapped = false
    titleLabel.TextTruncate = Enum.TextTruncate.AtEnd
    titleLabel.Font = Enum.Font.GothamSemibold
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.TextYAlignment = Enum.TextYAlignment.Center
    titleLabel.Parent = button

    button.MouseEnter:Connect(function()
        if button.BackgroundColor3 ~= Color3.fromRGB(70, 70, 70) then
            tween(button, {BackgroundColor3 = Color3.fromRGB(50, 50, 50)}, 0.14)
        end
    end)
    button.MouseLeave:Connect(function()
        if button.BackgroundColor3 ~= Color3.fromRGB(70, 70, 70) then
            tween(button, {BackgroundColor3 = Color3.fromRGB(37, 37, 37)}, 0.14)
        end
    end)

    return button
end

local function seedWindow(config)
    local gui = createGui((config.Title or "LibraryUI") .. "Gui")
    local theme = config.Theme or Library.Options.Theme
    local themePalettes = {
        Dark = {
            Background = Color3.fromRGB(20, 20, 20),
            Border = Color3.fromRGB(60, 60, 60),
            Tab = Color3.fromRGB(40, 40, 40),
            Active = Color3.fromRGB(70, 70, 70),
            Text = Color3.fromRGB(220, 220, 220),
            Accent = Color3.fromRGB(120, 120, 255),
        },
        Light = {
            Background = Color3.fromRGB(245, 245, 245),
            Border = Color3.fromRGB(195, 195, 195),
            Tab = Color3.fromRGB(225, 225, 225),
            Active = Color3.fromRGB(200, 200, 200),
            Text = Color3.fromRGB(25, 25, 25),
            Accent = Color3.fromRGB(80, 120, 255),
        },
    }
    local colors = themePalettes[theme] or themePalettes.Dark

    local window = Instance.new("Frame")
    window.Name = "Window"
    window.Size = config.Size or Library.Options.DefaultWindowSize
    window.Position = config.Position or UDim2.new(0.5, 0, 0.5, 0)
    window.AnchorPoint = Vector2.new(0.5, 0.5)
    window.BackgroundColor3 = colors.Background
    window.BorderSizePixel = 0
    window.Parent = gui

    local dragging = false
    local dragInput, dragStart, startPos
    local UserInputService = game:GetService("UserInputService")
    local function updateDrag(input)
        local delta = input.Position - dragStart
        window.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end

    local outer = Instance.new("Frame")
    outer.Name = "Border"
    outer.BackgroundColor3 = colors.Border
    outer.Size = UDim2.new(1, 1, 1, 1)
    outer.Position = UDim2.new(0, -1, 0, -1)
    outer.BorderSizePixel = 0
    outer.ZIndex = 0
    outer.Parent = window

    addUICorner(window, 14)
    addUIStroke(window, Color3.fromRGB(80, 80, 80), 1)

    local titleBar = Instance.new("Frame")
    titleBar.Name = "TitleBar"
    titleBar.BackgroundColor3 = Color3.fromRGB(28, 28, 28)
    titleBar.BorderSizePixel = 0
    titleBar.Size = UDim2.new(1, 0, 0, 36)
    titleBar.Position = UDim2.new(0, 0, 0, 0)
    titleBar.Parent = window

    local titleLabel = createLabel(config.Title or "UI Window", UDim2.new(1, 0, 0, 36), titleBar)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Font = Enum.Font.GothamSemibold
    titleLabel.TextSize = 16
    titleLabel.TextColor3 = colors.Text
    titleLabel.Size = UDim2.new(1, -90, 0, 36)
    titleLabel.TextYAlignment = Enum.TextYAlignment.Center
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Text = "  " .. (config.Title or "UI Window")

    local minimizeButton = Instance.new("TextButton")
    minimizeButton.Name = "Minimize"
    minimizeButton.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    minimizeButton.BorderSizePixel = 0
    minimizeButton.Size = UDim2.new(0, 30, 0, 30)
    minimizeButton.Position = UDim2.new(1, -36, 0, 3)
    minimizeButton.Text = "▁"
    minimizeButton.TextColor3 = Color3.fromRGB(220, 220, 220)
    minimizeButton.Font = Enum.Font.SourceSansBold
    minimizeButton.TextSize = 18
    minimizeButton.Parent = titleBar

    addUICorner(minimizeButton, 8)
    addUIStroke(minimizeButton, Color3.fromRGB(70, 70, 70), 1)

    titleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = window.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    titleBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input == dragInput then
            updateDrag(input)
        end
    end)

    local tabBar = Instance.new("Frame")
    tabBar.Name = "TabBar"
    tabBar.BackgroundTransparency = 1
    tabBar.Size = UDim2.new(1, 0, 0, Library.Options.TabHeight)
    tabBar.Position = UDim2.new(0, 0, 0, 36)
    tabBar.Parent = window

    local tabLayout = Instance.new("UIListLayout")
    tabLayout.FillDirection = Enum.FillDirection.Horizontal
    tabLayout.HorizontalAlignment = Enum.HorizontalAlignment.Left
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Padding = UDim.new(0, 2)
    tabLayout.Parent = tabBar

    local contentHolder = Instance.new("Frame")
    contentHolder.Name = "Content"
    contentHolder.BackgroundTransparency = 1
    contentHolder.Size = UDim2.new(1, 0, 1, -(36 + Library.Options.TabHeight))
    contentHolder.Position = UDim2.new(0, 0, 0, 36 + Library.Options.TabHeight)
    contentHolder.Parent = window

    local contentLayout = Instance.new("UIListLayout")
    contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
    contentLayout.Padding = UDim.new(0, 6)
    contentLayout.Parent = contentHolder

    local windowObject = {
        Gui = gui,
        Window = window,
        TabButtons = {},
        TabContents = {},
        SelectedIndex = 0,
    }

    window.IsMinimized = false
    window.FullSize = window.Size

    local function setMinimized(state)
        if window.IsMinimized == state then
            return
        end
        window.IsMinimized = state
        if state then
            minimizeButton.Text = "+"
            tabBar.Visible = false
            contentHolder.Visible = false
            tween(window, {Size = UDim2.new(window.Size.X.Scale, window.Size.X.Offset, 0, 46)}, 0.2)
        else
            minimizeButton.Text = "▁"
            tabBar.Visible = true
            contentHolder.Visible = true
            tween(window, {Size = window.FullSize}, 0.2)
        end
    end

    minimizeButton.MouseButton1Click:Connect(function()
        setMinimized(not window.IsMinimized)
    end)

    UserInputService.InputBegan:Connect(function(input, gameProcessedEvent)
        if gameProcessedEvent then
            return
        end
        local key = config.MinimizeKey or Library.Options.MinimizeKey
        if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == key then
            setMinimized(not window.IsMinimized)
        end
    end)

    function windowObject:SelectTab(index)
        for i, content in ipairs(self.TabContents) do
            content.Frame.Visible = (i == index)
            tween(self.TabButtons[i], {BackgroundColor3 = (i == index and colors.Active or colors.Tab)}, 0.18)
        end
        self.SelectedIndex = index
    end

    function windowObject:Minimize()
        setMinimized(true)
    end

    function windowObject:Restore()
        setMinimized(false)
    end

    function windowObject:AddTab(props)
        local name = props.Title or "Tab"
        local button = createTabButton(name, props.Icon, props.IconSize, UDim2.new(0, Library.Options.TabWidth, 1, 0), tabBar)

        local content = Instance.new("Frame")
        content.Name = name:gsub("%s+", "") .. "Content"
        content.BackgroundTransparency = 1
        content.Size = UDim2.new(1, 0, 1, 0)
        content.Visible = false
        content.Parent = contentHolder

        local contentLayout = Instance.new("UIListLayout")
        contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
        contentLayout.Padding = UDim.new(0, 8)
        contentLayout.Parent = content

        local tabObject = {
            Button = button,
            Content = content,
            Name = name,
        }

        function tabObject:AddSection(title)
            local section = createSectionContainer(self.Content)
            local titleLabel = createLabel(title, UDim2.new(1, 0, 0, 24), section)
            titleLabel.Font = Enum.Font.SourceSansBold
            titleLabel.TextSize = 16
            titleLabel.TextXAlignment = Enum.TextXAlignment.Left
            titleLabel.Text = title
            return setmetatable({
                Frame = section,
                    AddButton = function(_, props)
                    local button = createButton(props.Title or "Button", UDim2.new(1, 0, 0, 28), section)
                    if props.Tooltip then
                        button.Tooltip = props.Tooltip
                    end
                    button.MouseButton1Click:Connect(function()
                        if props.Callback then
                            props.Callback()
                        end
                    end)
                    return button
                end,
                CreateButton = function(self, title, callback, color, width)
                    return self:AddButton({ Title = title, Callback = callback })
                end,
                AddToggle = function(_, id, props)
                    local frame = createControlFrame(props.Title or id, section)
                    local button = createButton(props.Default and "ON" or "OFF", UDim2.new(0.3, 0, 1, 0), frame)
                    button.Position = UDim2.new(0.7, 0, 0, 0)
                    button.TextScaled = true
                    button.MouseButton1Click:Connect(function()
                        local value = not props.Default
                        props.Default = value
                        button.Text = value and "ON" or "OFF"
                        if props.Callback then
                            props.Callback(value)
                        end
                    end)
                    return frame
                end,
                CreateToggle = function(self, title, default, color, width, callback)
                    return self:AddToggle(title, { Title = title, Default = default, Callback = callback })
                end,
                AddDropdown = function(_, id, props)
                    local dropdownFrame = Instance.new("Frame")
                    dropdownFrame.BackgroundTransparency = 1
                    dropdownFrame.Size = UDim2.new(1, 0, 0, 30)
                    dropdownFrame.Parent = section

                    local label = createLabel(props.Title or id, UDim2.new(0.4, 0, 1, 0), dropdownFrame)
                    label.Text = props.Title or id

                    local button = createButton(props.Default or "Select", UDim2.new(0.6, 0, 1, 0), dropdownFrame)
                    button.Position = UDim2.new(0.4, 0, 0, 0)
                    button.TextXAlignment = Enum.TextXAlignment.Left

                    local list = createListFrame(section)
                    local current = props.Default

                    local function refreshLabel()
                        button.Text = tostring(current)
                    end

                    for _, value in ipairs(props.Values or {}) do
                        local item = createButton(tostring(value), UDim2.new(1, 0, 0, 26), list)
                        item.TextXAlignment = Enum.TextXAlignment.Left
                        item.MouseButton1Click:Connect(function()
                            if props.Multi then
                                current = current or {}
                                if type(current) ~= "table" then current = {current} end
                                if table.find(current, value) then
                                    table.remove(current, table.find(current, value))
                                else
                                    table.insert(current, value)
                                end
                            else
                                current = value
                                list.Visible = false
                            end
                            refreshLabel()
                            if props.Callback then
                                props.Callback(current)
                            end
                        end)
                    end

                    button.MouseButton1Click:Connect(function()
                        list.Visible = not list.Visible
                    end)

                    refreshLabel()
                    return dropdownFrame
                end,
                CreateDropdown = function(self, title, values, default, width, callback)
                    return self:AddDropdown(title, { Title = title, Values = values, Default = default, Callback = callback })
                end,
                AddSlider = function(_, id, props)
                    local sliderFrame = createControlFrame(props.Title or id, section)
                    local minus = createButton("-", UDim2.new(0.15, 0, 1, 0), sliderFrame)
                    minus.Position = UDim2.new(0.55, 0, 0, 0)
                    local valueLabel = createLabel(tostring(props.Default or props.Minimum or 0), UDim2.new(0.15, 0, 1, 0), sliderFrame)
                    valueLabel.Position = UDim2.new(0.7, 0, 0, 0)
                    valueLabel.TextScaled = true
                    valueLabel.TextXAlignment = Enum.TextXAlignment.Center
                    local plus = createButton("+", UDim2.new(0.15, 0, 1, 0), sliderFrame)
                    plus.Position = UDim2.new(0.85, 0, 0, 0)
                    local minimum = props.Minimum or 0
                    local maximum = props.Maximum or 100
                    local step = props.Rounding or 1
                    local current = props.Default or minimum

                    local function updateValue(newValue)
                        current = math.clamp(newValue, minimum, maximum)
                        valueLabel.Text = tostring(current)
                        if props.Callback then
                            props.Callback(current)
                        end
                    end

                    minus.MouseButton1Click:Connect(function()
                        updateValue(current - step)
                    end)
                    plus.MouseButton1Click:Connect(function()
                        updateValue(current + step)
                    end)

                    return sliderFrame
                end,
                CreateSlider = function(self, title, default, minimum, maximum, rounding, callback)
                    return self:AddSlider(title, { Title = title, Default = default, Minimum = minimum, Maximum = maximum, Rounding = rounding, Callback = callback })
                end,
                AddInput = function(_, id, props)
                    local inputFrame = createControlFrame(props.Title or id, section)
                    local textBox = Instance.new("TextBox")
                    textBox.Size = UDim2.new(0.6, 0, 1, 0)
                    textBox.Position = UDim2.new(0.4, 0, 0, 0)
                    textBox.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
                    textBox.BorderSizePixel = 0
                    textBox.Text = props.Default or ""
                    textBox.TextColor3 = Color3.fromRGB(255, 255, 255)
                    textBox.PlaceholderText = props.Placeholder or ""
                    textBox.Font = Enum.Font.SourceSans
                    textBox.TextSize = 16
                    textBox.Parent = inputFrame
                    textBox.FocusLost:Connect(function(enterPressed)
                        if props.Callback then
                            props.Callback(textBox.Text)
                        end
                    end)
                    return inputFrame
                end,
                CreateInput = function(self, title, default, placeholder, callback)
                    return self:AddInput(title, { Title = title, Default = default, Placeholder = placeholder, Callback = callback })
                end,
                AddParagraph = function(_, props)
                    local paragraph = Instance.new("TextLabel")
                    paragraph.BackgroundTransparency = 1
                    paragraph.Size = UDim2.new(1, 0, 0, 42)
                    paragraph.Text = props.Text or props.Title or ""
                    paragraph.TextWrapped = true
                    paragraph.TextColor3 = Color3.fromRGB(235, 235, 235)
                    paragraph.Font = Enum.Font.SourceSans
                    paragraph.TextSize = 14
                    paragraph.TextXAlignment = Enum.TextXAlignment.Left
                    paragraph.TextYAlignment = Enum.TextYAlignment.Top
                    paragraph.Parent = section
                    return paragraph
                end,
                CreateLabel = function(self, text)
                    return self:AddParagraph({ Text = text })
                end,
            }, { __index = function(tbl, key)
                return rawget(tbl, key)
            end })
        end

        table.insert(self.TabButtons, button)
        table.insert(self.TabContents, { Frame = content })

        button.MouseButton1Click:Connect(function()
            self:SelectTab(#self.TabButtons)
        end)

        function tabObject:CreateSection(title)
            return self:AddSection(title)
        end

        return setmetatable(tabObject, {
            __index = function(table, key)
                return rawget(table, key)
            end,
        })
    end

    function windowObject:CreateTab(title, active, icon, iconPosition, iconSize)
        local tab = self:AddTab({ Title = title, Icon = icon, IconSize = iconSize })
        if active then
            self:SelectTab(#self.TabButtons)
        end
        return tab
    end

    return windowObject
end

function Library:CreateWindow(config, ...)
    if type(config) ~= "table" then
        local title, subtitle, introText, introIcon, disableThemes, folder, theme = config, ...
        config = {
            Title = title,
            Subtitle = subtitle,
            IntroText = introText,
            IntroIcon = introIcon,
            DisableThemes = disableThemes,
            Folder = folder,
            Theme = theme,
        }
    end
    return seedWindow(config or {})
end

function Library:CreateNotification(props, content, duration)
    if type(props) == "string" then
        props = {
            Title = props,
            Content = content or "",
            Duration = duration,
        }
    end
    self:Notify(props)
end

function Library:Notify(props)
    pcall(function()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = props.Title or "Notification",
            Text = props.Content or props.Text or "",
            Duration = props.Duration or 5,
        })
    end)
end

