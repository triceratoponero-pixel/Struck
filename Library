--// Utility Functions
local function MakeDraggable(topbarobject, object)
    local Dragging = nil
    local DragInput = nil
    local DragStart = nil
    local StartPosition = nil
    
    local function Update(input)
        local Delta = input.Position - DragStart
        local pos = UDim2.new(StartPosition.X.Scale, StartPosition.X.Offset + Delta.X, StartPosition.Y.Scale, StartPosition.Y.Offset + Delta.Y)
        object.Position = pos
    end
    
    topbarobject.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            DragStart = input.Position
            StartPosition = object.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    Dragging = false
                end
            end)
        end
    end)
    
    topbarobject.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            DragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == DragInput and Dragging then
            Update(input)
        end
    end)
end

local function TweenObject(obj, properties, duration, easingStyle, easingDirection)
    local tween = TweenService:Create(obj, TweenInfo.new(duration or 0.25, easingStyle or Enum.EasingStyle.Quart, easingDirection or Enum.EasingDirection.Out), properties)
    tween:Play()
    return tween
end

local function CreateInstance(className, properties)
    local instance = Instance.new(className)
    for prop, value in pairs(properties) do
        instance[prop] = value
    end
    return instance
end

local function Corner(parent, radius)
    local corner = CreateInstance("UICorner", {
        CornerRadius = UDim.new(0, radius or 6),
        Parent = parent
    })
    return corner
end

local function Stroke(parent, color, thickness)
    local stroke = CreateInstance("UIStroke", {
        Color = color or CurrentTheme.Outline,
        Thickness = thickness or 1,
        Parent = parent
    })
    return stroke
end

local function Padding(parent, padding)
    local pad = CreateInstance("UIPadding", {
        PaddingLeft = UDim.new(0, padding or 10),
        PaddingRight = UDim.new(0, padding or 10),
        PaddingTop = UDim.new(0, padding or 10),
        PaddingBottom = UDim.new(0, padding or 10),
        Parent = parent
    })
    return pad
end

--// Config System
function VisualUI:SaveConfig(name)
    if not name or name == "" then return end
    local configData = {}
    -- Config data would be populated by elements
    if not isfolder(ConfigFolder) then
        makefolder(ConfigFolder)
    end
    writefile(ConfigFolder .. "/" .. name .. ".json", HttpService:JSONEncode(configData))
end

function VisualUI:LoadConfig(name)
    if not name or name == "" then return end
    local path = ConfigFolder .. "/" .. name .. ".json"
    if isfile(path) then
        local data = HttpService:JSONDecode(readfile(path))
        return data
    end
end

function VisualUI:GetConfigs()
    if not isfolder(ConfigFolder) then
        makefolder(ConfigFolder)
        return {}
    end
    local configs = {}
    for _, file in ipairs(listfiles(ConfigFolder)) do
        if file:match("%.json$") then
            table.insert(configs, file:match("([^/\\]+)%.json$"))
        end
    end
    return configs
end

function VisualUI:DeleteConfig(name)
    if not name or name == "" then return end
    local path = ConfigFolder .. "/" .. name .. ".json"
    if isfile(path) then
        delfile(path)
    end
end

--// Theme System
function VisualUI:ChangeTheme(theme)
    if type(theme) == "string" then
        if Themes[theme] then
            CurrentTheme = Themes[theme]
        end
    elseif type(theme) == "table" then
        CurrentTheme = theme
    end
end

function VisualUI:GetThemes()
    local themeNames = {}
    for name, _ in pairs(Themes) do
        table.insert(themeNames, name)
    end
    return themeNames
end

function VisualUI:ReturnTheme()
    return CurrentTheme
end

function VisualUI:ChangeColor(index, color)
    if CurrentTheme[index] then
        CurrentTheme[index] = color
    end
end

