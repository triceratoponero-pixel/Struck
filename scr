function getCrosshairs()
    local crosshairs = {all = {}, purple = {}}
    local particles = Workspace:FindFirstChild("Particles")
    if not particles then
        return crosshairs
    end

    local currentField = findField(api.humanoidrootpart().Position)
    for _, v in pairs(particles:GetChildren()) do
        if v.Name == "Crosshair" and findField(v.Position) == currentField then
            if not v:FindFirstChild("Collected") then
                local brickColor = v.BrickColor
                if brickColor == BrickColor.new("Red flip/flop") then
                    table.insert(crosshairs.all, v)
                elseif brickColor == BrickColor.new("Alder") then
                    table.insert(crosshairs.all, v)
                    table.insert(crosshairs.purple, v)
                end
            end
        end
    end
    return crosshairs
end

function updateCrosshairs(shouldLock, exception)
    local crosshairs = getCrosshairs()
    for _, v in pairs(crosshairs.all) do
        if shouldLock and v ~= exception and v.BrickColor == BrickColor.new("Red flip/flop") then
            v.CanCollide = true
        elseif not shouldLock then
            v.CanCollide = false
        end
    end
end

function farmCrosshair(crosshair, save_height)
    if not crosshair or not crosshair.Parent then
        return
    end

    local PathfindingService = game:GetService("PathfindingService")
    local Path = PathfindingService:CreatePath({
        AgentRadius = 5,
        WaypointSpacing = 6,
        Costs = {
            Crosshair = math.huge
        }
    })

    updateCrosshairs(true, crosshair)
    local hrp = api.humanoidrootpart()
    if not hrp then
        lockMovement(false)
        return
    end

    local success = pcall(function()
        Path:ComputeAsync(hrp.Position, crosshair.Position)
    end)

    if success and Path then
        local points = Path:GetWaypoints()
        lockMovement(true)
        for _, v in pairs(points) do
            if not crosshair.Parent then
                lockMovement(false)
                return
            end
            if save_height and save_height ~= crosshair.Position.Y then
                lockMovement(false)
                return
            end
            if (crosshair.Position - api.humanoidrootpart().Position).Magnitude < 4 then
                break
            end

            local hum = api.humanoid()
            if not hum then
                lockMovement(false)
                return
            end

            local moveComplete = false
            local startTime = tick()
            hum:MoveTo(v.Position)
            local signal
            signal = hum.MoveToFinished:Connect(function()
                moveComplete = true
                pcall(function()
                    signal:Disconnect()
                end)
            end)
            repeat
                task.wait()
            until moveComplete or (tick() - startTime) > 0.85 or not crosshair.Parent or (save_height and save_height ~= crosshair.Position.Y) or api.magnitude(crosshair.Position) < 5
        end
        lockMovement(false)
    end

    markAsCollected(crosshair)
    local hum = api.humanoid()
    if hum then
        repeat
            task.wait()
            hum:MoveTo(crosshair.Position)
        until not crosshair.Parent or (save_height and save_height ~= crosshair.Position.Y)
    end
    updateCrosshairs(false)
end

function smartFarmCrosshairs()
    local buffStack = tonumber(getBuffStack("Precision")) or 0
    local buffTime = tonumber(getBuffTime("Precision")) or 0
    local isFarmed = false

    if buffStack < 10 or buffTime <= 30 then
        local crosshairs = getCrosshairs()
        for _, crosshair in pairs(crosshairs.all) do
            if not crosshair or not crosshair.Parent then
                continue
            end
            local MoveToFinished = false
            local started = tick()
            local save_height = crosshair.Position.Y
            local brickColor = crosshair.BrickColor
            if brickColor == BrickColor.new("Forest green") or brickColor == BrickColor.new("Royal purple") then
                continue
            end

            lockMovement(true)
            local hum = api.humanoid()
            if hum then
                hum:MoveTo(crosshair.Position)
                local signal
                signal = hum.MoveToFinished:Connect(function()
                    MoveToFinished = true
                    pcall(function()
                        signal:Disconnect()
                    end)
                end)
                repeat
                    task.wait()
                until MoveToFinished or (save_height and save_height ~= crosshair.Position.Y) or (tick() - started) > 5 or api.magnitude(crosshair.Position) < 4 or not crosshair.Parent
            end
            lockMovement(false)
            markAsCollected(crosshair)
            isFarmed = true
        end
    elseif buffStack == 10 and buffTime > 30 then
        local crosshairs = getCrosshairs()
        for _, crosshair in pairs(crosshairs.purple) do
            if not crosshair or not crosshair.Parent then
                continue
            end
            local save_height = crosshair.Position.Y
            if Pacific.autoFarmSettings.smartPreciseMethod == "Walk" then
                isFarmed = true
                farmCrosshair(crosshair, save_height)
            else
                repeat
                    task.wait()
                    if api.magnitude(crosshair.Position) > 5 then
                        startTween(crosshair.Position - Vector3.new(0, 1.8, 0), 350)
                    end
                until not crosshair.Parent or (save_height and save_height ~= crosshair.Position.Y) or #crosshairs.purple > 1
                markAsCollected(crosshair)
                isFarmed = true
            end
            break
        end
    end
    return isFarmed
end

function getSpawnerTime(spawner, extraSeconds)
    if not spawner then
        return math.huge
    end
    local spawnerInfo = monstersTable[spawner.Name]
    if not spawnerInfo then
        return math.huge
    end

    local lastKillTime = getClientStatCache("MonsterTimes", spawner.Name) or 0
    local spawnerCooldown = ClientMonsterTools and ClientMonsterTools.GetSpawnerCooldown and ClientMonsterTools.GetSpawnerCooldown(spawner.Name)
    local currentTime = ServerTime and ServerTime() or tick()

    if not spawnerCooldown then
        return math.huge
    end

    local timeLeft = (lastKillTime + spawnerCooldown - currentTime) + (tonumber(extraSeconds) or 0)
    if timeLeft < 0 then
        timeLeft = 0
    end

    return timeLeft
end

