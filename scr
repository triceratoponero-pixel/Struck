                table.insert(quests, {Name = v.Name, npc = npc})
            end
        end
    end

    return prioritizeQuests(quests)
end

function collectNearestTokens(nearPos, magnitude)
    if not nearPos then
        nearPos = api.humanoidrootpart().Position
    elseif typeof(nearPos) == "Instance" then
        if nearPos:IsA("BasePart") or nearPos:IsA("Model") then
            nearPos = nearPos.Position
        elseif nearPos:FindFirstChild("Position") then
            nearPos = nearPos.Position
        else
            nearPos = api.humanoidrootpart().Position
        end
    elseif typeof(nearPos) ~= "Vector3" then
        nearPos = api.humanoidrootpart().Position
    end

    local collectibles = Workspace:FindFirstChild("Collectibles")
    if not collectibles then
        return
    end

    for _, v in pairs(collectibles:GetChildren()) do
        if not v.Parent or not v:IsA("BasePart") then
            continue
        end
        if table.find(temptable.susTokenPositions, v.Position) then
            continue
        end
        if api.magnitude(nearPos, v.Position) < (magnitude or 30)
            and api.magnitude(nearPos * Vector3.new(0, 1, 0), v.Position * Vector3.new(0, 1, 0)) < 10 then
            collectToken(v)
            task.wait()
        end
    end
end

function farmBubbles()
    local speedModified = false
    local bubblesToCollect = {}
    local particles = Workspace:FindFirstChild("Particles")
    if not particles then
        return
    end

    for _, v in pairs(particles:GetChildren()) do
        if v.Name:find("Bubble") and findField(v.Position) == temptable.fieldSelected then
            if #bubblesToCollect == 0 then
                if not Pacific.toggles.smartBlueAutofarm then
                    table.insert(bubblesToCollect, v)
                else
                    if temptable.fieldPosition and api.magnitude(temptable.fieldPosition, v.Position) < 30 then
                        table.insert(bubblesToCollect, v)
                    end
                end
            else
                -- Check for nearest bubbles
                if api.magnitude(v.Position, bubblesToCollect[#bubblesToCollect].Position) < 15 then
                    table.insert(bubblesToCollect, v)
                end
            end
        end
    end

    if #bubblesToCollect >= 3 then
        if temptable.speedMultiplier == 1 then
            speedModified = true
            temptable.speedMultiplier = 1.3
        end
        for _, bubble in ipairs(bubblesToCollect) do
            if not Pacific.toggles.autofarm then
                break
            end
            if not bubble.Parent then
                continue
            end
            local hum = api.humanoid()
            if hum then
                repeat
                    task.wait()
                    hum:MoveTo(bubble.Position)
                until api.magnitude(api.humanoidrootpart().Position, bubble.Position) <= 14 or not Pacific.toggles.autofarm or not bubble.Parent
            end
        end
    end
    if speedModified then
        temptable.speedMultiplier = 1
    end
end

function farmShowerAndCoco()
    if #temptable.showersTable > 0 and Pacific.autoFarmSettings.farmShower then
        while #temptable.showersTable > 0 do
            local key, warningisk = next(temptable.showersTable)
            if warningisk and warningisk.Parent and warningisk.Transparency > 0.09 then
                startTween(warningisk.Position, 350)
                tween(0.05, warningisk.Position, true)
                repeat
                    task.wait()
                until not warningisk.Parent or warningisk.Transparency <= 0.08
                temptable.showersTable[key] = nil
            else
                temptable.showersTable[key] = nil
            end
            task.wait()
        end
        collectNearestTokens()
    elseif #temptable.coconutsTable > 0 and Pacific.autoFarmSettings.farmCoconuts then
        while #temptable.showersTable <= 0 and #temptable.coconutsTable > 0 do
            local key, warningisk = next(temptable.coconutsTable)
            if warningisk and warningisk.Parent and warningisk.Transparency > 0.09 then
                startTween(warningisk.Position, 350)
                tween(0.150, warningisk.Position)
                repeat
