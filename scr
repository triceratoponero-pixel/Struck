function farmDupedTokens()
    if #temptable.dupedTokensTable == 0 then
        return false
    end

    local dupedToken = next(temptable.dupedTokensTable)
    if not dupedToken then
        return false
    end
    if tonumber(dupedToken) then
        dupedToken = temptable.dupedTokensTable[dupedToken]
    end
    if not dupedToken or not dupedToken.Parent then
        return false
    end

    local attachment = dupedToken:FindFirstChild("Attachment")
    if not attachment then
        return false
    end
    local billboardGui = attachment:FindFirstChild("BillboardGuiFront")
    if not billboardGui then
        return false
    end
    local smile = billboardGui:FindFirstChild("Smile")
    if not smile then
        return false
    end

    local succ, err = pcall(function()
        while smile.ImageColor3 ~= Color3.fromRGB(255, 0, 255) do
            if not dupedToken or not dupedToken.Parent then
                break
            end
            local pos = dupedToken.Position - Vector3.new(0, 10, 0)
            local hum = api.humanoid()
            if hum then
                hum:MoveTo(pos)
            end
            task.wait(0.05)
        end

        local index = table.find(temptable.dupedTokensTable, dupedToken)
        if index then
            table.remove(temptable.dupedTokensTable, index)
        end
    end)

    if not succ then
        warn("[Pacific] farmDupedTokens error:", err)
    end
    return succ
end

function mainAutofarmFunction()
    local function importantFarmTaskCallback(token)
        if not token or not token.Position then
            return false
        end
        return findField(token.Position) == temptable.fieldSelected
    end

    while task.wait() do
        xpcall(function()
            if temptable.stopEverything then
                task.wait(0.03)
                return
            end

            if temptable.autoRBC.isActive then
                task.wait(0.03)
                return
            end

            if canTaskBeSpawned("getToys") then
                getToys()
            end

            if Pacific.autoPlantersSettings.doCustomPlanters and canTaskBeSpawned("farmPlanters") then
                if autoPlanters() then
                    return
                end
            end

            if Pacific.combatSettings.killVicious and temptable.detected.vicious and canTaskBeSpawned("killVicious") then
                killVicious()
            end

            tryKillMonsters()

            if canTaskBeSpawned("trainBosses") then
                if Pacific.combatSettings.trainKingBeetle then
                    trainKingBeetle()
                end
                if Pacific.combatSettings.trainTunnelBear then
                    trainTunnelBear()
                end
                if Pacific.combatSettings.trainCrab then
                    trainCrab()
                end
                if Pacific.combatSettings.trainStumpSnail then
                    if trainStumpSnail() then
                        return
                    end
                end
            end

            if not Pacific.toggles.convertHoney or not shouldIConvert() then
                if temptable.shouldEquipDefaultMask then
                    temptable.shouldEquipDefaultMask = false
                    requestAccessoryEquip(Pacific.vars.defaultmask)
                    return
                end

                if temptable.puffsDetected and Pacific.autoPuffshroomSettings.farmPuffshrooms then
                    farmPuffshrooms()
                    return
                end

                if Pacific.autoFarmSettings.farmSprouts then
                    farmSprouts()
                end

                selectField(Pacific.autoFarmSettings.field)

                if Pacific.autoQuestSettings.doQuests then
                    doQuests()
                end

                if not isFieldSame(api.humanoidrootpart().Position, temptable.fieldPosition) then
                    moveTo(temptable.fieldPosition + Vector3.new(0, 3, 0))
                    if Pacific.autoFarmSettings.autoSprinkler and placeSprinklers then
                        task.wait()
                        placeSprinklers(temptable.fieldPosition)
                    end
                end

                if Pacific.autoFarmSettings.smartPreciseCrosshair then
                    local crosshairs = getCrosshairs()
                    if crosshairs and #crosshairs.all > 0 then
                        if smartFarmCrosshairs() then
                            return
                        end
                    end
                end

                if Pacific.autoFarmSettings.farmDupedTokens then
                    farmDupedTokens()
                end

                if Pacific.autoFarmSettings.farmShower or Pacific.autoFarmSettings.farmCoconuts then
                    farmShowerAndCoco()
                end

                local isFarmed = farmNearest(importantFarmTaskCallback)

                if Pacific.autoFarmSettings.farmUnderBalloons and math.random(68, 70) == 69 then
                    local farmed = gotoNearestBalloon()
                    isFarmed = isFarmed or farmed
                end

                if not isFarmed and (tick() - temptable.lastWalkToNearest > 1.5) then
                    local randomFlower = getRandomFlower(temptable.fieldSelected)
                    if randomFlower then
                        temptable.lastWalkToNearest = tick()
                        local hum = api.humanoid()
                        if hum then
                            hum:MoveTo(randomFlower.Position)
                        end
                    end
                end
            elseif Pacific.toggles.convertHoney and shouldIConvert(false, false) then
                convertHoney(Pacific.toggles.converthiveballoon)
            end
        end, function(err)
            warn("[Pacific] (" .. temptable.version .. ") | An error has occurred: " .. tostring(err))
        end)
    end
end

