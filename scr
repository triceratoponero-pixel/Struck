function claimQuests()
    local npcs = Workspace:FindFirstChild("NPCs")
    if not npcs then
        return
    end
    local screenGui = player:WaitForChild("PlayerGui", 5):FindFirstChild("ScreenGui")
    if not screenGui then
        return
    end

    for _, v in pairs(npcs:GetChildren()) do
        local shouldClaim = getQuestSetting(v.Name, "toggle")
            or (Pacific.autoQuestSettings.acceptAllQuests
                and v.Name ~= "Honey Bee"
                and v.Name ~= "Gummy Bear"
                and v.Name ~= "Bubble Bee Man 2"
                and v.Name ~= "Ant Challenge Info"
                and v.Name ~= "Wind Shrine")

        if shouldClaim and Pacific.autoQuestSettings.doQuests then
            local platform = v:FindFirstChild("Platform")
            if not platform then
                continue
            end
            local alertPos = platform:FindFirstChild("AlertPos")
            if not alertPos then
                continue
            end
            local alertGui = alertPos:FindFirstChild("AlertGui")
            if not alertGui then
                continue
            end
            local imageLabel = alertGui:FindFirstChild("ImageLabel")
            if not imageLabel or imageLabel.ImageTransparency ~= 0 then
                continue
            end

            if Pacific.toggles.tptonpc then
                local hrp = api.humanoidrootpart()
                if hrp then
                    hrp.CFrame = CFrame.new(platform.Position + Vector3.new(0, 3, 0))
                end
            else
                moveTo(platform.Position)
                task.wait(0.03)
            end

            local npcScreen = screenGui:FindFirstChild("NPC")
            local attempts = 0
            while imageLabel.ImageTransparency == 0 and api.magnitude(platform.Position) <= 25 and attempts < 5 do
                if api.magnitude(platform.Position) <= 25 and npcScreen and not npcScreen.Visible then
                    local tempTimestamp = tick()
                    repeat
                        if not (api.magnitude(platform.Position) < 25) then
                            break
                        end
                        if setIdentity then
                            setIdentity(2)
                        end
                        if ActivatablesNPC and ActivatablesNPC.ButtonEffect then
                            ActivatablesNPC.ButtonEffect(player, npcs[v.Name])
                        end
                        if setIdentity then
                            setIdentity(origThreadIdentity)
                        end
                        task.wait(1.5)
                    until npcScreen.Visible or tick() - tempTimestamp > 10
                end

                if npcScreen then
                    local tempTimestamp = tick()
                    repeat
                        task.wait()
                    until npcScreen.Visible or tick() - tempTimestamp > 10

                    while npcScreen.Visible do
                        local optionFrame = npcScreen:FindFirstChild("OptionFrame")
                        if optionFrame then
                            local option2 = optionFrame:FindFirstChild("Option2")
                            if option2 and option2.Visible and option2.Text and option2.Text:find("Talk to") then
                                if setIdentity then
                                    setIdentity(2)
                                end
                                if firesignal then
                                    firesignal(option2.MouseButton1Click)
                                end
                                if setIdentity then
                                    setIdentity(origThreadIdentity)
                                end
                            else
                                local buttonOverlay = npcScreen:FindFirstChild("ButtonOverlay")
                                if buttonOverlay then
                                    if setIdentity then
                                        setIdentity(2)
                                    end
                                    if firesignal then
                                        firesignal(buttonOverlay.MouseButton1Click)
                                    end
                                    if setIdentity then
                                        setIdentity(origThreadIdentity)
                                    end
                                end
                            end
                        end
                        task.wait()
                    end
                end

                task.wait(2.5)
                attempts = attempts + 1
            end
            task.wait(0.5)
        end
    end
end

function doQuests(NPC)
    NPC = NPC or false
    claimQuests()
    local questTasks = getQuestTasks(NPC)
    for _, questTask in pairs(questTasks) do
        if not questTask then
            continue
        end

        local taskDescription = questTask.Description
        if typeof(taskDescription) ~= "string" then
            if setIdentity then
                setIdentity(2)
            end
            taskDescription = taskDescription(getClientStatCache())
            if setIdentity then
                setIdentity(origThreadIdentity)
            end
        end

        if questTask.Type == "Collect Pollen" or questTask.Type == "Collect Goo" then
            local newField = getQuestTaskField(questTask)
            if newField then
                local flowerZones = Workspace:FindFirstChild("FlowerZones")
                if flowerZones and flowerZones:FindFirstChild(newField) then
                    selectField(newField)
                    break
                end
            end
        elseif questTask.Type == "Defeat Monsters" then
            local monsterToKill = questTask.MonsterType
            local numberOfMonsters = questTask.Amount
            local monsterSpawners = getSpawnedMonsters(monsterToKill)
            local remainingAmount = numberOfMonsters - (questTask.Progress and questTask.Progress[2] or 0)

            if #monsterSpawners > 0 then
                for _, spawnerConfig in pairs(monsterSpawners) do
                    if remainingAmount <= 0 then
                        break
                    end
                    if not isMonsterKilled(spawnerConfig.Spawner.Name) then
                        local isKilled = killMonster(spawnerConfig.Territory, spawnerConfig.Spawner)
                        if isKilled then
                            task.wait(1)
                            for _ = 1, 5 do
                                collectNearestTokens(nil, 20)
                            end
                            remainingAmount = remainingAmount - 1
                        end
                    end
                end
            end
        elseif questTask.Type == "Use Items" then
            if taskDescription and string.find(taskDescription, "Feed") then
                if not temptable.questFeedCooldown then
                    if Events and Events.ClientCall then
                        Events.ClientCall("ConstructHiveCellFromEgg", math.random(1, 5), 1, questTask.Item, questTask.Amount, false)
                    end
                    temptable.questFeedCooldown = true
                    task.wait(5)
                    temptable.questFeedCooldown = false
                end
            else
                -- UseItem - currently disabled
                if false and questTask.Item and not questTask.Item:find("Jelly") then
                    if not temptable.questUseItemCooldown then
                        local playerActives = game:GetService("ReplicatedStorage"):FindFirstChild("Events")
                        if playerActives then
                            local cmd = playerActives:FindFirstChild("PlayerActivesCommand")
                            if cmd then
                                cmd:FireServer({["Name"] = questTask.Item})
                            end
                        end
                        task.spawn(function()
                            temptable.questUseItemCooldown = true
                            task.wait(100)
                            temptable.questUseItemCooldown = false
                        end)
                    end
                end
            end
        elseif questTask.Type == "Use Toy" then
            if canToyBeUsed(questTask.Toy) and not temptable.questUseToyCooldown then
                if not questTask.Toy:find("Glue") then
                    useToy(questTask.Toy)
                else
                    useGlueDispenser()
                end
                temptable.questUseToyCooldown = true
                task.wait(15)
                temptable.questUseToyCooldown = false
                continue
            end
        elseif questTask.Type == "Match Pairs" then
            for _, v in pairs(AllToysTable["memoryMatchTable"] or {}) do
                useMemoryMatch(v, true)
            end
        elseif questTask.Type == "Complete Quests" then
            doQuests(questTask.Pool or "Polar Bear")
        end
    end
end

