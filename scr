function destroyBodyGyro()
    if not (player and player.Character and player.Character:FindFirstChild('UpperTorso')) then return end
    local characterTorso = player.Character:FindFirstChild('UpperTorso')
    local bodyGyro = characterTorso:FindFirstChildOfClass('BodyGyro')
    if bodyGyro then bodyGyro:Destroy() end
end

function lookAt(targetPos)
    if not (player and player.Character and player.Character:FindFirstChild('UpperTorso')) then return end
    local characterTorso = player.Character:FindFirstChild('UpperTorso')
    local bodyGyro = characterTorso:FindFirstChildOfClass('BodyGyro') or Instance.new('BodyGyro')
    bodyGyro.MaxTorque = Vector3.new(0, math.huge, 0)
    bodyGyro.D = 10
    bodyGyro.P = 5000
    bodyGyro.CFrame = CFrame.new(characterTorso.CFrame.p, targetPos)
    bodyGyro.Parent = characterTorso
end

Tasks:Add('Auto Face', function()
    while task.wait() do
        if not (Pacific.autoFarmSettings.faceCenter or Pacific.autoFarmSettings.faceBalloons or Pacific.autoFarmSettings.faceFlames) then
            destroyBodyGyro()
            task.wait(0.5)
            continue
        end

        if not api.humanoidrootpart() or not player.Character then
            destroyBodyGyro()
            task.wait(1)
            continue
        end

        local characterTorso = player.Character:FindFirstChild('UpperTorso')
        local playerStandsOn = findField(api.humanoidrootpart().Position)
        if not playerStandsOn or not characterTorso then
            destroyBodyGyro()
            task.wait(0.1)
            continue
        end

        if Pacific.autoFarmSettings.faceCenter then
            lookAt(playerStandsOn.Position)
            continue
        end

        if Pacific.autoFarmSettings.faceBalloons then
            local bestBalloon = getBestFieldBalloon()
            if bestBalloon and bestBalloon:FindFirstChild('BalloonBody') then
                lookAt(bestBalloon.BalloonBody.Position)
            else
                destroyBodyGyro()
            end
            continue
        end

        if Pacific.autoFarmSettings.faceFlames then
            local pos = nil
            local playerFlames = Workspace:FindFirstChild('PlayerFlames')
            if playerFlames then
                for i, v in pairs(playerFlames:GetChildren()) do
                    pcall(function()
                        if v:FindFirstChild('PF') and v.PF.Color.Keypoints[1].Value.G ~= 0 then
                            local hrp = api.humanoidrootpart()
                            if hrp and (v.Position - hrp.Position).Magnitude < 20 then
                                pos = v.Position
                            end
                        end
                    end)
                    if pos then break end
                end
            end
            if pos then
                lookAt(pos)
            else
                destroyBodyGyro()
            end
            continue
        end
    end
end, true)

if _G.debugging then
    warn('UI init done.')
end
