function webhookFieldsList()
    local currentHoney = getClientStatCache("Totals", "Honey") or 0
    local timePassed = math.round(tick() - currentPacificLoadedAt)
    local honeyGained = currentHoney - (temptable.honeyAtStart or 0)
    local honeyPerHour = timePassed > 0 and math.floor((honeyGained / timePassed) * 3600) or 0
    local dailyHoney = getDailyHoney() or 0

    local totalHoneyString = truncate(currentHoney)
    local honeyGainedString = truncate(honeyGained)
    local honeyPerHourString = truncate(honeyPerHour)
    local honeyPerDayString = truncate(dailyHoney)

    if not Pacific.webhookSettings.onlyTruncated then
        totalHoneyString = addcommas(currentHoney) .. " (" .. totalHoneyString .. ")"
        honeyGainedString = addcommas(honeyGained) .. " (" .. honeyGainedString .. ")"
        honeyPerHourString = addcommas(honeyPerHour) .. " (" .. honeyPerHourString .. ")"
        honeyPerDayString = addcommas(dailyHoney) .. " (" .. honeyPerDayString .. ")"
    end

    local uptimeString = truncatetime(timePassed)
    local fields = {}

    if Pacific.webhookSettings.showTotalHoney then
        table.insert(fields, {
            name = "Total Honey:",
            value = totalHoneyString,
            inline = false
        })
    end

    table.insert(fields, {
        name = "Session Honey:",
        value = honeyGainedString,
        inline = true
    })
    table.insert(fields, {
        name = "Session Uptime:",
        value = uptimeString,
        inline = true
    })

    if Pacific.webhookSettings.showHoneyPerHour then
        table.insert(fields, {
            name = "Honey Per Hour:",
            value = honeyPerHourString,
            inline = false
        })
    end

    if Pacific.webhookSettings.showDailyHoney then
        table.insert(fields, {
            name = "Honey Per Day:",
            value = honeyPerDayString,
            inline = false
        })
    end

    if Pacific.webhookSettings.showNectars then
        local nectars = getAllNectar(true)
        local nectarsString = ""
        if nectars then
            for _, nectar in pairs(nectars) do
                if nectar.time == 0 then
                    continue
                end
                nectarsString = nectarsString .. (nectarEmojis[nectar.name] or nectar.name .. ":") .. " " .. tostring(nectar.time) .. "
"
            end
        end
        if #nectarsString > 1 then
            table.insert(fields, {
                name = "Nectars:",
                value = nectarsString,
                inline = false
            })
        end
    end

    if Pacific.webhookSettings.showPlanters then
        local plantersString = ""
        pcall(function()
            local minePlanters = getMinePlanters()
            for _, v in pairs(minePlanters) do
                local potModel = v.PotModel
                if potModel then
                    local emoji = plantersEmojis[potModel.Name] or "🌱"
                    local growth = v.GrowthPercent and math.floor(v.GrowthPercent * 1000) / 10 or 0
                    plantersString = plantersString .. emoji .. " " .. growth .. "%
"
                end
            end
        end)
        if plantersString ~= "" then
            table.insert(fields, {
                name = "Active Planters",
                value = plantersString,
                inline = false
            })
        end
    end

    if Pacific.webhookSettings.showItems then
        local itemsString = ""
        for _, item in pairs(Pacific.webhookSettings.itemsList or {}) do
            local systemItem = getItemByName(item)
            if systemItem and systemItem.SystemName then
                local count = getClientStatCache("Eggs", systemItem.SystemName) or 0
                itemsString = itemsString .. item .. ": **" .. tostring(count) .. "**
"
            end
        end
        if itemsString ~= "" then
            table.insert(fields, {
                name = "Items",
                value = itemsString,
                inline = false
            })
        end
    end

    return fields
end

function generateWebhookBody(settings)
    if not settings then
        settings = {}
    end
    local color = tonumber(settings.color) or tonumber(Pacific.webhookSettings.webhookColor) or 0xfcdf03

    local body = {
        username = player.Name,
        content = settings.content or "",
        embeds = {{
            title = "**" .. (settings.embedTitle or "Pacific") .. "**",
            description = settings.embedDescription or "",
            type = "rich",
            color = color,
            fields = settings.fields or {},
            footer = {
                text = os.date("%x") .. " • " .. os.date("%I") .. ":" .. os.date("%M") .. " " .. os.date("%p")
            }
        }}
    }
    return body
end

