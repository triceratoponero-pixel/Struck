function trainTunnelBear()
    if not Pacific.combatSettings.trainTunnelBear then
        return
    end
    local spawned = getSpawnedMonsters("Tunnel Bear")
    if #spawned ~= 1 then
        return
    end

    if tunnelPart then
        tunnelPart.CanCollide = true
    end
    local spawner = spawned[1].Spawner

    while Pacific.combatSettings.trainTunnelBear and not isMonsterKilled(spawner.Name) do
        if api.magnitude(tunnelPart.Position) > 10 then
            moveTo(tunnelPart.Position)
        end
        task.wait(0.1)
    end

    if tunnelPart then
        tunnelPart.CanCollide = false
    end
    task.wait(1)

    if #getSpawnedMonsters("Tunnel Bear") == 0 then
        task.wait(0.5)
        for _ = 1, 10 do
            if api.magnitude(tunnelPart.Position) > 250 then
                moveTo(tunnelPart.Position - Vector3.new(0, 16, 0))
            end
            collectNearestTokens(nil, 250)
        end
        task.wait(0.5)
    end
end

