function useToy(toyName, collectTokens)
    if not canToyBeUsed(toyName) then
        return
    end

    local toys = Workspace:FindFirstChild("Toys")
    if not toys then
        return
    end
    local toy = toys:FindFirstChild(toyName)
    if not toy then
        return
    end

    local platform = toy:FindFirstChild("Platform")
    if not platform then
        return
    end

    local patformPosition = platform.Position + Vector3.new(0, 3, 0)
    task.wait()

    while not temptable.convertingHoney and canToyBeUsed(toyName) do
        if api.magnitude(patformPosition) > 20 then
            moveTo(patformPosition)
            task.wait(0.25)
        end
        if api.magnitude(patformPosition) < 20 then
            if secureCall then
                secureCall(ActivatablesToys.ButtonEffect, Activatables, player, toy)
            end
        end
        task.wait(2)
    end

    if collectTokens then
        task.wait(1.5)
        local tokensNear = {}
        if temptable.tokenpath then
            for _, token in pairs(temptable.tokenpath:GetChildren()) do
                if api.magnitude(token.Position, patformPosition) < 25
                    and token.CFrame.YVector.Y == 1
                    and getTokenId(token) ~= "65867881" then
                    table.insert(tokensNear, token)
                end
            end
        end

        while #tokensNear > 0 do
            for i = #tokensNear, 1, -1 do
                local token = tokensNear[i]
                if api.magnitude(patformPosition) > 25 then
                    moveTo(patformPosition)
                end
                if not token or not token.Parent then
                    table.remove(tokensNear, i)
                    continue
                end
                collectToken(token)
            end
            task.wait()
        end
    end
end

