        return
    end

    if position then
        local temp1 = nil
        task.spawn(function()
            temp1 = walkTo(position, 2)
        end)
        repeat
            task.wait()
        until temp1 ~= nil
    end

    if not withoutJump then
        task.wait(0.1)
        humanoid.Jump = true
        task.wait(0.2)
    end

    local playerActives = player:FindFirstChild("PlayerActivesCommand")
    if playerActives then
        playerActives:FireServer({["Name"] = "Sprinkler Builder"})
    end

    if not withoutWait then
        task.wait(1)
    end
end

local sprinklerCounts = {
    ["The Supreme Saturator"] = 1,
    ["Basic Sprinkler"] = 1,
    ["Silver Soakers"] = 2,
    ["Golden Gushers"] = 3,
    ["Diamond Drenchers"] = 4
}

function placeSprinklers(fieldPos)
    if not fieldPos then
        return
    end

    local sprinkler = getClientStatCache("EquippedSprinkler")
    if not sprinkler then
        return
    end

    local sprinklersToPlace = sprinklerCounts[sprinkler] or 0
    if sprinklersToPlace == 0 then
        return
    end

    local placedSprinklersCount = 0
    local gadgets = Workspace:FindFirstChild("Gadgets")
    if gadgets then
        for _, v in pairs(gadgets:GetChildren()) do
            if v.Name == sprinkler then
                local base = v:FindFirstChild("Base")
                if base and isFieldSame(fieldPos, base.Position) then
                    placedSprinklersCount = placedSprinklersCount + 1
                end
            end
        end
    end

    if placedSprinklersCount >= sprinklersToPlace then
        return
    end

    local flowerSize = 4
    local centerPos = fieldPos

    if sprinklersToPlace == 1 then
        placeSprinkler(centerPos, true, true)
    elseif sprinklersToPlace == 2 then
        placeSprinkler(centerPos + Vector3.new(-3 * flowerSize, 0, -3 * flowerSize))
        placeSprinkler(centerPos + Vector3.new(3 * flowerSize, 0, 3 * flowerSize), true, false)
    elseif sprinklersToPlace == 3 then
        placeSprinkler(centerPos + Vector3.new(3 * flowerSize, 0, -3 * flowerSize))
        placeSprinkler(centerPos + Vector3.new(-4 * flowerSize, 0, -3 * flowerSize))
        placeSprinkler(centerPos + Vector3.new(0, 0, 3 * flowerSize), true, false)
    elseif sprinklersToPlace == 4 then
        placeSprinkler(centerPos + Vector3.new(-4 * flowerSize, 0, 0))
        placeSprinkler(centerPos + Vector3.new(4 * flowerSize, 0, 0))
        placeSprinkler(centerPos + Vector3.new(0, 0, 4 * flowerSize))
        placeSprinkler(centerPos + Vector3.new(0, 0, -4 * flowerSize), true, false)
    end
end

-- ============================================
-- BEE RARITY & AUTO RJ SYSTEM
-- ============================================

function getBeeRarity(beeName)
    if not beeName then
        return ""
    end
    local cleanName = beeName:gsub(" Bee", "")
    local fullBeeData = beesTable.fullData and beesTable.fullData[cleanName]
    if fullBeeData then
        return fullBeeData.Rarity or ""
    end
    return ""
end

function isBeeExpected(beeCell)
    if not beeCell then
        return false
    end
    local cellType = beeCell:FindFirstChild("CellType")
    if not cellType then
        return false
    end

    local beeName = cellType.Value:gsub("Bee", " Bee")
    local beeRarity = getBeeRarity(beeName)
    local isGifted = beeCell:FindFirstChild("GiftedCell") and true or false

    local stop = false

    if temptable.autoRJSettings.requireAnyGifted and isGifted then
        stop = true
    end

    if table.find(temptable.autoRJSettings.selectedRarities, "Any " .. beeRarity)
        or (table.find(temptable.autoRJSettings.selectedRarities, "Gifted Any " .. beeRarity) and isGifted) then
        stop = true
    end

    if table.find(temptable.autoRJSettings.selectedBees, beeName)
        or (table.find(temptable.autoRJSettings.selectedBees, "Gifted " .. beeName) and isGifted) then
        stop = true
    end

    return stop
end

