local newMemoryMatchStartGame = function() end
local MemoryMatchStartGame

if not getgenv().autoMMConfigured then
    getgenv().autoMMConfigured = true

    local function UpdateGameTable(a)
        if not a or not a.Game or not a.Game.RevealedTiles then
            return {}
        end
        local dupes = {}
        local exclude = a.Game.MatchedTiles or {}

        for index, value in pairs(a.Game.RevealedTiles) do
            if exclude[index] == nil then
                if dupes[value] == nil then
                    dupes[value] = {Indexes = {index}}
                else
                    table.insert(dupes[value]["Indexes"], index)
                end
            end
        end

        for i, v in pairs(dupes) do
            if #v.Indexes < 2 then
                dupes[i] = nil
            end
        end

        return dupes
    end

    newMemoryMatchStartGame = function(a)
        if not Pacific.toggles.automemorymatch and not Pacific.autoQuestSettings.useMemoryMatch then
            return
        end
        if not a or not a.Game or not a.Game.Grid then
            return
        end

        repeat
            task.wait()
        until a.Game.Grid.InputActive

        temptable.activeMemoryMatch = a
        local numTiles = a.Game.NumTiles or 0

        for Index = 1, numTiles do
            task.wait()
            if a.Game.Chances and a.Game.Chances == 0 then
                break
            end

            if setIdentity then
                setIdentity(2)
            end
            local tile
            xpcall(function()
                tile = a.Game.Grid:GetTileAtIndex(Index)
            end, function(err)
                warn("[Pacific] MM Err:", err)
            end)
            if setIdentity then
                setIdentity(origThreadIdentity)
            end

            if a.Game.LastSelectedIndex ~= nil then
                local searchFor = a.Game.RevealedTiles[a.Game.LastSelectedIndex]
                local dupes = UpdateGameTable(a)
                for i2, v2 in pairs(dupes) do
                    if i2 == searchFor and v2.Indexes[1] ~= Index then
                        if setIdentity then
                            setIdentity(2)
                        end
                        xpcall(function()
                            tile = a.Game.Grid:GetTileAtIndex(v2.Indexes[1])
                        end, function(err)
                            warn("[Pacific] MM tile err:", err)
                        end)
                        if setIdentity then
                            setIdentity(origThreadIdentity)
                        end
                        break
                    end
                end
            else
                local dupes = UpdateGameTable(a)
                for _, v in pairs(dupes) do
                    if #v.Indexes > 1 then
                        if setIdentity then
                            setIdentity(2)
                        end
                        if MemoryMatchModule and MemoryMatchModule.RegisterTileSelected then
                            MemoryMatchModule.RegisterTileSelected(a.Game, a.Game.Grid:GetTileAtIndex(v.Indexes[1]))
                        end
                        if setIdentity then
                            setIdentity(origThreadIdentity)
                        end
                        repeat
                            task.wait()
                        until not a.Game.Grid.InputActive or (a.Game.Chances and a.Game.Chances <= 0)
                        if setIdentity then
                            setIdentity(2)
                        end
                        xpcall(function()
                            tile = a.Game.Grid:GetTileAtIndex(v.Indexes[2])
                        end, function(err)
                            warn("[Pacific] MM tile2 err:", err)
                        end)
                        if setIdentity then
                            setIdentity(origThreadIdentity)
                        end
                        task.wait()
                        break
                    end
                end
            end

            if setIdentity then
                setIdentity(2)
            end
            if MemoryMatchModule and MemoryMatchModule.RegisterTileSelected and tile then
                MemoryMatchModule.RegisterTileSelected(a.Game, tile)
            end
            if setIdentity then
                setIdentity(origThreadIdentity)
            end
            repeat
                task.wait()
            until not a.Game.Grid.InputActive or (a.Game.Chances and a.Game.Chances <= 0)
            task.wait()
        end

        warn("[Pacific] Finishing memory Match")
        if Events and Events.ClientCall then
            Events.ClientCall("MemoryMatchEvent", {
                Action = "Finish"
            })
        end
        warn("[Pacific] Ending Game")
        if setIdentity then
            setIdentity(2)
        end
        if MinigameGui and MinigameGui.EndGame then
            MinigameGui.EndGame()
        end
        if setIdentity then
            setIdentity(origThreadIdentity)
        end
        warn("[Pacific] Game ended successfully")
        temptable.activeMemoryMatch = nil
    end

    if MinigameGui and MinigameGui.StartGame then
        MemoryMatchStartGame = MinigameGui.StartGame
        local hookedMemoryMatchStartGame
        hookedMemoryMatchStartGame = hookfunction(MemoryMatchStartGame, function(...)
            local a = hookedMemoryMatchStartGame(...)
            coroutine.wrap(function()
                task.wait(1)
                newMemoryMatchStartGame(a)
            end)()
            return a
        end)
    end
end

