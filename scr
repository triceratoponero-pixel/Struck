    end)

    if isPoolQuest then
        local temp = getClientStatCache("Quests", "PoolLastQuests", tostring(originalNPC))
        if temp then
            local tempQuestInfo = getQuestInfo(temp)
            if tempQuestInfo then
                QuestName = tempQuestInfo.DisplayName or tempQuestInfo.Name
            end
        end
    end

    local suffix = ""
    if NPC == "Polar Bear" then
        suffix = "

" .. (miscEmojis["Polar Power"] or "🐻‍❄️") .. " x" .. polarPower
    else
        local countNum = tonumber(questCount)
        if countNum then
            suffix = "

Total " .. NPC .. "'s quests completed: " .. questCount
        else
            suffix = "

..."
        end
    end

    local fields = {}
    if isPoolQuest then
        table.insert(fields, {
            name = "Completed Repeatable Quest",
            value = (QuestName or NPC) .. suffix
        })
    else
        table.insert(fields, {
            name = "Completed Quest",
            value = QuestName or "Unknown Quest"
        })
    end

    questWebhook(NPC, fields)
end

