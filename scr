function getPartsFromRay(origin, direction, whitelist)
    if typeof(whitelist) == "Instance" then
        whitelist = whitelist:GetDescendants()
    elseif whitelist == nil then
        whitelist = {}
    end

    local Parts = {}
    local LastPart
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Whitelist
    raycastParams.FilterDescendantsInstances = whitelist

    repeat
        local result = workspace:Raycast(origin, direction, raycastParams)
        LastPart = result and result.Instance
        if LastPart then
            table.insert(Parts, LastPart)
            -- Add to ignore list for next raycast
            local currentIgnore = table.clone(raycastParams.FilterDescendantsInstances)
            table.insert(currentIgnore, LastPart)
            raycastParams.FilterDescendantsInstances = currentIgnore
        end
    until LastPart == nil

    return Parts
end

