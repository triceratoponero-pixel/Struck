        ["Shocked"] = 45, ["Diamond"] = 28, ["Buoyant"] = 29, ["Vicious"] = 22,
        ["Festive"] = 24, ["Crimson"] = 11, ["Stubborn"] = 46, ["Carpenter"] = 19,
        ["Commander"] = 25, ["Exhausted"] = 38
    },

    farmField = function(field)
        if not field then
            return
        end
        local hrp = api.humanoidrootpart()
        if not hrp or not (findField(hrp.Position) == field) then
            moveTo(field.Position + Vector3.new(0, 3, 0))
            task.wait(0.5)
            local playerActives = player:FindFirstChild("PlayerActivesCommand")
            if playerActives then
                playerActives:FireServer({["Name"] = "Sprinkler Builder"})
            end
            task.wait()
        end

        if not Pacific.toggles.autodig and autoDig then
            autoDig.Set(true)
        end

        local function importantFarmTaskCallback(token)
            if not token or not token.Position then
                return false
            end
            return findField(token.Position) == field
        end

        local isFarmed = farmNearest(importantFarmTaskCallback)

        if not isFarmed and (tick() - temptable.lastWalkToNearest > 3) then
            local randomFlower = getRandomFlower(field)
            if randomFlower then
                temptable.lastWalkToNearest = tick()
                local hum = api.humanoid()
                if hum then
                    hum:MoveTo(randomFlower.Position)
                end
            end
        end
    end,

    getTaskField = function(questTask)
        if not questTask then
            return Pacific.autoQuestSettings.bestRedField
        end
        if questTask.Zone then
            return questTask.Zone
        elseif questTask.Color then
            return Pacific.autoQuestSettings["best" .. questTask.Color .. "Field"]
        else
            return Pacific.autoQuestSettings.bestRedField
        end
    end
}

autoRBC.Functions = {
    getActiveChallange = function()
        if not secureCall then
            return nil
        end
        return secureCall(RoboBearGui.GetActiveChallengeData, Activatables)
    end,

    selectQuest = function()
        if Events and Events.ClientCall then
            Events.ClientCall("RoboBearQuestSelect", math.random(1, 2))
        end
    end,

    selectBee = function(beesTable)
        if not beesTable then
            return
        end
        local playerFile = getClientStatCache()
        local bestBee = {priority = math.huge, index = 1, beeName = nil}

        for beeIndex = 1, #beesTable do
            local obfuscatedBee = beesTable[beeIndex]
            if not obfuscatedBee or #obfuscatedBee < 2 then
                continue
            end
            local obfuscatedBeeX = obfuscatedBee[1]
            local obfuscatedBeeY = obfuscatedBee[2]

            local beeFile
            if secureCall then
                beeFile = secureCall(StatTools.GetBeeFile, Activatables, playerFile, obfuscatedBeeX, obfuscatedBeeY)
            end
            if beeFile and beeFile.Type then
                local beePriority = autoRBC.redBeesPriorityList[beeFile.Type]
                if beePriority and beePriority < bestBee.priority then
                    bestBee.priority = beePriority
                    bestBee.index = beeIndex
                    bestBee.beeName = beeFile.Type
                end
            end
        end
        if Events and Events.ClientCall then
            Events.ClientCall("RoboBearBeeSelect", bestBee.index or 1)
        end
    end,

    chooseUpgrades = function()
        if Events and Events.ClientCall then
            Events.ClientCall("RoboBearRoundStart")
        end
    end,

    onRoundStart = function()
        while task.wait() do
            local currentChallangeData = autoRBC.Functions.getActiveChallange()
            if not currentChallangeData then
                return
            end

            local playerFile = getClientStatCache()
            local ActiveQuest = currentChallangeData.ActiveQuest
            if not ActiveQuest or not ActiveQuest.Tasks then
                continue
            end

            local tasks = ActiveQuest.Tasks
            local progress
            if secureCall then
                progress = secureCall(Quests.GetProgression, Activatables, nil, tasks, playerFile)
            end
            if not progress then
                continue
            end

            local HttpService = game:GetService("HttpService")
            pcall(function()
                writefile("rbc/progress_1.json", HttpService:JSONEncode(progress))
                writefile("rbc/teasks_1.json", HttpService:JSONEncode(tasks))
            end)

            for i, v in ipairs(tasks) do
                if not progress[i] or progress[i][1] >= 1 then
                    continue
                end
                local taskType = v.Type
                if taskType == "Collect Pollen" or taskType == "Make Honey" or taskType == "Collect Goo" then
                    local taskTable = {}
                    if taskType == "Collect Pollen" then
                        taskTable.Color = v.Color
                        taskTable.Zone = v.Zone
                    elseif taskType == "Make Honey" or taskType == "Collect Goo" then
                        taskTable.Color = "Red"
                    end
                    local fieldName = autoRBC.getTaskField(taskTable)
                    if fieldName then
                        local flowerZones = Workspace:FindFirstChild("FlowerZones")
                        if flowerZones then
                            local fieldObj = flowerZones:FindFirstChild(fieldName)
                            if fieldObj then
                                pcall(function()
                                    autoRBC.farmField(fieldObj)
                                end)
                            end
                        end
                    end
                end
                break
            end
        end
    end,

    onRoundEnd = function()
        local playerInventory = getClientStatCache("Eggs")
        if not playerInventory or not playerInventory.Cogs then
            return
        end

        local function buyDrive(driveName)
            local targetPos = Vector3.new(-473, 60, 106)
            if player:DistanceFromCharacter(targetPos) > 25 then
                moveTo(targetPos)
                task.wait(0.25)
            end
            task.wait(0.25)
            if Events and Events.ClientCall then
                Events.ClientCall("ItemPackageEvent", "Purchase", {
                    Type = "Robo Bear " .. driveName,
                    Amount = 1,
                    Category = "Bundle"
                })
            end
            task.wait(0.1)
        end

        while playerInventory.Cogs >= 50 do
            if (playerInventory.WhiteDrive or 0) < 5 then
                buyDrive("White Drive")
            elseif (playerInventory.RedDrive or 0) < 5 then
                buyDrive("Red Drive")
            elseif (playerInventory.BlueDrive or 0) < 5 then
                buyDrive("Blue Drive")
            elseif (playerInventory.GlitchedDrive or 0) < 5 then
                buyDrive("Glitched Drive")
            else
                break
            end
        end
        task.wait()
        autoRBC.Functions.takeRBQuest()
    end,

    onChallangeEnd = function()
        for _, v in pairs(autoRBC.Listeners) do
            pcall(function()
                v:Disconnect()
            end)
        end
        table.clear(autoRBC.Listeners)

        if Events and Events.ClientCall then
            Events.ClientCall("RoboBearClaimRewards")
        end

        temptable.autoRBC.latestRBC = tick() + 5
        task.wait(2.5)
        temptable.autoRBC.isActive = false
    end,

    takeRBQuest = function()
        warn("[Pacific] Taking RB Quest")
        local attempts = 0
        local activaChallange = autoRBC.Functions.getActiveChallange()

        while (not activaChallange or activaChallange.RoundState ~= "Running") and attempts < 5 do
            local roboBear = Workspace:FindFirstChild("Toys") and Workspace.Toys:FindFirstChild("Robo Bear")
            if not roboBear then
                break
            end
            local platform = roboBear:FindFirstChild("Platform")
            if not platform then
                break
            end

            local screenGui = player:WaitForChild("PlayerGui", 5):FindFirstChild("ScreenGui")
            local npcScreen = screenGui and screenGui:FindFirstChild("NPC")

            if api.magnitude(platform.Position) <= 25 and npcScreen and not npcScreen.Visible then
                local tempTimestamp = tick()
                repeat
                    if api.magnitude(platform.Position) > 25 then
                        break
                    end
                    if secureCall then
                        secureCall(ActivatablesNPC.ButtonEffect, Activatables, player, roboBear)
                    end
                    task.wait(0.5)
                until npcScreen.Visible or tick() - tempTimestamp > 10
            elseif api.magnitude(platform.Position) > 25 then
                moveTo(platform.Position + Vector3.new(0, 3, 0))
                task.wait(0.5)
                continue
            end

            if not npcScreen then
                break
            end

            local tempTimestamp = tick()
            repeat
                task.wait()
            until npcScreen.Visible or tick() - tempTimestamp > 10

            while npcScreen.Visible do
                local optionFrame = npcScreen:FindFirstChild("OptionFrame")
                local option1 = optionFrame and optionFrame:FindFirstChild("Option1")
                local optionText = option1 and option1.Text
                local buttonOverlay = npcScreen:FindFirstChild("ButtonOverlay")

                if optionFrame and option1 and option1.Visible and optionText and (optionText:find("Spend 1 Robo Pass") or optionText:find("Start Round")) then
                    if setIdentity then
                        setIdentity(2)
                    end
                    if firesignal then
                        firesignal(option1.MouseButton1Click)
                    end
                    if setIdentity then
                        setIdentity(origThreadIdentity)
                    end
                elseif buttonOverlay then
                    if setIdentity then
                        setIdentity(2)
                    end
                    if firesignal then
                        firesignal(buttonOverlay.MouseButton1Click)
                    end
                    if setIdentity then
                        setIdentity(origThreadIdentity)
                    end
                end
                task.wait()
            end

            task.wait(2.5)
            attempts = attempts + 1
            activaChallange = autoRBC.Functions.getActiveChallange()
        end
        task.wait(0.5)
        return autoRBC.Functions.getActiveChallange()
    end
}

function mainAutoRBCFunction()
    warn("[Pacific] Starting Auto RBC")
    local eventsDir = game:GetService("ReplicatedStorage"):FindFirstChild("EventsDir")
    if not eventsDir then
        warn("[Pacific] EventsDir not found")
        return
    end

    local function safeConnect(eventName, callback)
        local event = eventsDir:FindFirstChild(eventName)
        if event and event.IsA and event:IsA("RemoteEvent") then
            return event.OnClientEvent:Connect(callback)
        end
        return nil
    end

    autoRBC.Listeners[1] = safeConnect("RoboBearQuestSelect", autoRBC.Functions.selectQuest)
    autoRBC.Listeners[2] = safeConnect("RoboBearBeeSelect", autoRBC.Functions.selectBee)
    autoRBC.Listeners[3] = safeConnect("RoboBearUpgradeSelect", autoRBC.Functions.chooseUpgrades)
    autoRBC.Listeners[4] = safeConnect("RoboBearRoundStart", autoRBC.Functions.onRoundStart)
    autoRBC.Listeners[5] = safeConnect("RoboBearRoundEnd", autoRBC.Functions.onRoundEnd)
    autoRBC.Listeners[6] = safeConnect("RoboBearChallengeEnd", autoRBC.Functions.onChallangeEnd)

    if autoRBC.Functions.takeRBQuest() then
        temptable.autoRBC.isActive = true
    end
end

