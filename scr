function trainStumpSnail()
    if not Pacific.combatSettings.trainStumpSnail then
        return false
    end
    if #getSpawnedMonsters("Stump Snail") < 1 then
        return false
    end

    if Pacific.combatSettings.snailConvertHoney and getBagPercentage() >= 99 then
        return convertHoney(false)
    end

    local flowerZones = Workspace:FindFirstChild("FlowerZones")
    local stumpField = flowerZones and flowerZones:FindFirstChild("Stump Field")
    if not stumpField then
        return false
    end

    local hrp = api.humanoidrootpart()
    if not hrp or not isFieldSame(hrp.Position, stumpField.Position) then
        moveTo(stumpField.Position)
        task.wait(2)
        if placeSprinkler then
            placeSprinkler(nil, true, true)
        end
    end

    local importantCallback = function(token)
        if not token or not token.Position then
            return false
        end
        if not (findField(token.Position) == stumpField) then
            return false
        end
        local snail = getAliveMonsters("Stump Snail")
        if not snail or #snail == 0 then
            return true
        end
        local snailHead = snail[1]:FindFirstChild("Head")
        if snailHead and api.magnitude(token.Position, (snailHead.Position - Vector3.new(0, 10, 0))) < 21 then
            return false
        end
        return true
    end

    local isFarmed = false
    for _ = 1, 5 do
        local farmed = farmToken(importantCallback)
        isFarmed = isFarmed or farmed
    end

    if not isFarmed and (tick() - temptable.lastWalkToNearest > 1.5) then
        local randomFlower = getRandomFlower(stumpField)
        local snail = getAliveMonsters("Stump Snail")
        if randomFlower and snail and #snail > 0 then
            local snailHead = snail[1]:FindFirstChild("Head")
            if snailHead and api.magnitude(randomFlower.Position, (snailHead.Position - Vector3.new(0, 10, 0))) > 40 then
                temptable.lastWalkToNearest = tick()
                local hum = api.humanoid()
                if hum then
                    hum:MoveTo(randomFlower.Position)
                end
                task.wait(0.1)
            end
        end
    end
    return true
end

