			return nil
		end
		for i, v in pairs(tt) do
			if v == va then
				return i
			end
		end
		return nil
	end

	Pacific["findValue"] = function(Table, Value)
		if type(Table) ~= "table" then
			return false
		end
		for _, value in pairs(Table) do
			if value == Value then
				return true
			end
		end
		return false
	end

	Pacific["returnValue"] = function(tab, val)
		local ok = false
		for _, v in pairs(tab) do
			if string.match(val, v) then
				ok = v
				break
			end
		end
		return ok
	end

