        local aLevel = aName and tonumber(string.match(aName, "Lvl (%d+)")) or 1
        local bRarity = bName and string.match(bName, "(%a*)%s+Puffshroom") or "Common"
        local bLevel = bName and tonumber(string.match(bName, "Lvl (%d+)")) or 1

        local aRarityValue = puffsRarityList[aRarity] or 1
        local bRarityValue = puffsRarityList[bRarity] or 1

        if aRarityValue == bRarityValue then
            if Pacific.autoPuffshroomSettings.levelPriority == "High > Low" then
                return aLevel > bLevel
            else
                return aLevel < bLevel
            end
        else
            if Pacific.autoPuffshroomSettings.rarityPriority == "Mythic > Common" then
                return aRarityValue > bRarityValue
            else
                return aRarityValue < bRarityValue
            end
        end
    end)

    local bestPuff = bestPuffs[1]
    if bestPuff then
        local puffName
        pcall(function()
            puffName = bestPuff["Puffball Top"].Attachment.Gui.NameRow.TextLabel.Text
        end)
        if puffName then
            local puffRarity = string.match(puffName, "(%a*)%s+Puffshroom") or "Common"
            local puffLevel = tonumber(string.match(puffName, "Lvl (%d+)"))
            return {
                Rarity = puffRarity,
                Level = puffLevel,
                Model = bestPuff
