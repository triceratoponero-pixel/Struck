function canTaskBeSpawned(taskName)
    if not taskName then return false end

    local puffshroomBlocking = temptable.puffsDetected and Pacific.autoPuffshroomSettings.farmPuffshrooms

    if taskName == "getToys" then
        return not puffshroomBlocking
    elseif taskName == "farmPlanters" then
        return not puffshroomBlocking
    elseif taskName == "killVicious" then
        return true
    elseif taskName == "trainBosses" then
        return not puffshroomBlocking
    end

    return false
end

function canCollectToken(token)
    if not token or not token.Parent then
        return false
    end

    local hrp = api.humanoidrootpart()
    if not hrp then
        return false
    end

    -- Check vertical distance only (Y-axis comparison)
    local verticalDist = math.abs((hrp.Position * Vector3.new(0, 1, 0) - token.Position * Vector3.new(0, 1, 0)).Magnitude)
    if verticalDist >= 6 then
        return false
    end

    -- FIX: Changed .magnitude to .Magnitude, fixed YVector check
    return token.CFrame.YVector.Y == 1
end

function canFarmTask(taskName)
    if not taskName then
        return false
    end

    if taskName == "getNearestBubble" and Pacific.autoFarmSettings.farmBubbles then
        return true
    elseif taskName == "getNearestFuzz" and Pacific.autoFarmSettings.farmFuzzyBombs then
        return true
    elseif taskName == "getNearestCloud" and Pacific.autoFarmSettings.farmUnderClouds then
        return true
    elseif taskName == "getNearestFlame" and Pacific.autoFarmSettings.farmFlames then
        return true
    elseif taskName == "getNearestToken" then
        return true
    end

    return false
end

function dig()
    if not std then
        warn("[Pacific] std (setthreadidentity) not available")
        return
    end
    std(2)
    local success = pcall(function()
        local localCollect = game:GetService("ReplicatedStorage"):FindFirstChild("Collectors")
        if localCollect then
            local module = localCollect:FindFirstChild("LocalCollect")
            if module then
                require(module).Run()
            end
        end
    end)
    if not success then
        warn("[Pacific] dig() failed")
    end
    std(8)
end

