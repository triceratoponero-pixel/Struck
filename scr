    if timeLeft > 0 then
        return true
    else
        return false
    end
end

function killMonster(territory, spawner)
    if not territory or not spawner then
        return false
    end
    local startTimeStamp = tick()
    temptable.doingMonster = true
    local hum = api.humanoid()
    if not hum then
        temptable.doingMonster = false
        return false
    end

    while not isMonsterKilled(spawner.Name) do
        if (tick() - startTimeStamp) > 60 then
            break
        end
        if api.magnitude(territory.Position) > 60 then
            moveTo(territory.Position)
            task.wait(0.25)
        end
        if spawner.Name:find("ForestMantis") then
            local targetPos = territory.Position + Vector3.new(0, 0, 15)
            if api.magnitude(targetPos) < 6 then
                hum:MoveTo(territory.Position - Vector3.new(0, 0, 15))
            else
                hum:MoveTo(targetPos)
            end
        end
        task.wait(0.5)
        jump()
        task.wait(1)
    end

    temptable.doingMonster = false
    return isMonsterKilled(spawner)
end

function killVicious()
    if not Pacific.combatSettings.killVicious or not temptable.detected.vicious then
        return
    end

    local viciousModel
    local particles = Workspace:FindFirstChild("Particles")
    local monsters = Workspace:FindFirstChild("Monsters")
    if not particles or not monsters then
        return
    end

    for _, v in pairs(particles:GetChildren()) do
        if v.Name:find("Vicious") then
            for _, v2 in pairs(monsters:GetChildren()) do
                if v2.Name:find("Vicious") then
                    local hrp = v2:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        viciousModel = v2
                        moveTo(v.Position)
                        task.wait(0.5)
                    end
                end
            end
        end
    end

    if not viciousModel then
        return
    end

    local viciousHRP = viciousModel:FindFirstChild("HumanoidRootPart")
    if not viciousHRP then
        return
    end

    local viciousOnField = findField(viciousHRP.Position)
    -- Extract level from name (e.g., "Vicious Bee Level 5")
    local levelStr = viciousModel.Name:match("%d+")
    local level = tonumber(levelStr)

    while viciousModel and viciousModel.Parent and Pacific.combatSettings.killVicious and temptable.detected.vicious do
        if not viciousModel.Parent then
            break
        end

        if viciousOnField then
            local currentField = findField(api.humanoidrootpart().Position)
            if currentField ~= viciousOnField then
                moveTo(viciousOnField.Position)
            end

            local updatedHRP = viciousModel:FindFirstChild("HumanoidRootPart")
            if updatedHRP and api.magnitude(updatedHRP.Position) > 50 then
                local hum = api.humanoid()
                if hum then
                    hum:MoveTo(updatedHRP.Position)
                end
                task.wait(0.75)
            end

            if collectNearestTokens then
                collectNearestTokens(nil, 70)
            end
            avoidWarningDisks()
        end
        task.wait()
    end
end

