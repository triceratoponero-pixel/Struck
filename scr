local function cleanupOldUI()
	local targetGui = gethui and gethui() or game:GetService("CoreGui")
	if not targetGui then return end

	for _, v in pairs(targetGui:GetDescendants()) do
		if v:IsA("TextLabel") and v.Name:find("vitaly") then
			local parent = v.Parent
			if parent then
				local toDestroy = v
				for _ = 1, 5 do
					if toDestroy and toDestroy.Parent then
						toDestroy = toDestroy.Parent
					else
						break
					end
				end
				if toDestroy and toDestroy ~= targetGui then
					pcall(function()
						toDestroy:Destroy()
					end)
				end
			end
		end
	end
end

