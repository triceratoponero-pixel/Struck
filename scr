function getBestFieldBalloon()
    local hrp = api.humanoidrootpart()
    if not hrp then
        warn("[Pacific] getBestFieldBalloon: HRP not found")
        return nil
    end

    local bestFieldBalloon = { instance = nil, mostBalloonsInRow = -1 }

    if not temptable.balloonsTable then
        return nil
    end

    for _, balloon in pairs(temptable.balloonsTable) do
        if not balloon or not balloon.Parent then
            continue
        end
        local balloonBody = balloon:FindFirstChild("BalloonBody")
        if not balloonBody then
            continue
        end

        local playerPos = hrp.Position + Vector3.new(0, 16, 0)
        local balloonPos = balloonBody.Position

        if not isFieldSame(playerPos - Vector3.new(0, 16, 0), balloonPos - Vector3.new(0, 16, 0)) then
            continue
        end

        -- Check if balloon is valid (not depleted)
        local isValid = false
        pcall(function()
            local guiAttach = balloonBody:FindFirstChild("GuiAttach")
            if guiAttach then
                local gui = guiAttach:FindFirstChild("Gui")
                if gui then
                    local bar = gui:FindFirstChild("Bar")
                    if bar then
                        isValid = bar.BackgroundTransparency ~= 1
                    end
                end
            end
        end)
        if not isValid then
            continue
        end

        -- FIX: Updated to workspace:Raycast instead of deprecated Ray.new
        local direction = Vector3.new(balloonPos.X, playerPos.Y, balloonPos.Z) - playerPos
        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Whitelist
        raycastParams.FilterDescendantsInstances = temptable.FieldBalloons or {}
        local result = workspace:Raycast(playerPos, direction, raycastParams)

        local intersection = {}
        if result then
            table.insert(intersection, result.Instance)
        end

        if #intersection >= bestFieldBalloon.mostBalloonsInRow then
            bestFieldBalloon.mostBalloonsInRow = #intersection
            bestFieldBalloon.instance = balloon
        end
    end

    return bestFieldBalloon.instance
end

function getPuffsOnField(field)
