function sendWebhook(body)
    if not body then
        warn("[Pacific] sendWebhook: No body provided")
        return
    end
    if not httpreq then
        warn("[Pacific] sendWebhook: httpreq not available")
        return
    end
    if not Pacific.webhookSettings.webhookUrl or Pacific.webhookSettings.webhookUrl == "" then
        return
    end

    local headers = {
        ["Content-Type"] = "application/json"
    }
    local HttpService = game:GetService("HttpService")

    xpcall(function()
        local encodedBody = HttpService:JSONEncode(body)
        httpreq({
            Url = Pacific.webhookSettings.webhookUrl,
            Body = encodedBody,
            Method = "POST",
            Headers = headers
        })
        task.wait()
        temptable.lastWebhookSent = math.round(tick())
    end, function(err)
        warn("[Pacific] (" .. tostring(temptable.version) .. ") | Failed to send webhook: " .. tostring(err))
    end)
end

function questWebhook(npc, fields)
    if not Pacific.webhookSettings.sendQuests then
        return
    end
    local thumbnail = npcsIcons and npcsIcons[npc] or nil
    local data = generateWebhookBody({
        embedTitle = "Pacific | Quests",
        thumbnail = thumbnail,
        fields = fields or {}
    })
    sendWebhook(data)
end

function sendHourlyWebhook(isTest)
    local ping = ""
    if Pacific.webhookSettings.pingUser and Pacific.webhookSettings.discordId and Pacific.webhookSettings.discordId ~= "0" then
        ping = "<@" .. Pacific.webhookSettings.discordId .. ">"
    end

    local content
    if isTest then
        if ping ~= "" then
            content = ping .. ", your webhook is working!"
        else
            content = "Your webhook is working!"
        end
    else
        content = ping
    end

    local data = generateWebhookBody({
        content = content,
        embedTitle = isTest and "Webhook Test" or "Honey Update",
        fields = webhookFieldsList()
    })
    sendWebhook(data)
end

function sendTestWebhook()
    local data = generateWebhookBody({
        embedTitle = "Test Webhook",
        embedDescription = "Hey from Pacific"
    })
    sendWebhook(data)
end

