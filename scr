function isFieldOccupied(field)
    if not field then
        return false
    end
    local planters = getMinePlanters()
    for _, planter in pairs(planters) do
        if planter.PotModel and planter.PotModel.Parent and planter.PotModel.PrimaryPart then
            local fieldFound = findField(planter.PotModel.PrimaryPart.Position)
            if fieldFound and fieldFound.Name == field then
                return true
            end
        end
    end
    return false
end

function isPlanterPlanted(planterName)
    if not planterName then
        return false
    end
    local planters = getMinePlanters()
    local planterData = getPlanterData(planterName)
    if not planterData then
        return false
    end
    for _, planter in pairs(planters) do
        if planter.Active and not planter.Collected and planter.Type == planterData.systemName then
            return true
        end
    end
    return false
end

function getBestPlanter(nectar, field, blacklisted)
    local bestPlanter = ""
    local bestZone = ""
    local bestNectarMultiplier = 0
    local bestZoneMultiplier = 0

    local flowerZones = Workspace:FindFirstChild("FlowerZones")
    if not flowerZones then
        return bestPlanter, bestZone
    end
    local fieldObj = flowerZones:FindFirstChild(field)
    if not fieldObj then
        return bestPlanter, bestZone
    end
    local colorGroup = fieldObj:FindFirstChild("ColorGroup")
    if not colorGroup then
        return bestPlanter, bestZone
    end
    local fieldColor = colorGroup.Value

    for planterName, planter in pairs(plantersTable) do
        if not planter then
            continue
        end
        local isBlacklisted = Pacific.autoPlantersSettings.blacklistedPlanters and table.find(Pacific.autoPlantersSettings.blacklistedPlanters, planter.systemName)
        if isBlacklisted then
            continue
        end
        if isPlanterPlanted(planterName) then
            continue
        end

        local hasPlanter = false
        if planterName ~= "Plenty" then
            hasPlanter = getClientStatCache("Eggs", planterName .. "Planter") ~= 0
        else
            hasPlanter = getClientStatCache("Eggs", "The Planter Of Plenty") ~= 0
        end
        if not hasPlanter then
            continue
        end

        local nectarMultiplier = (planter.nectarMultipliers and planter.nectarMultipliers[nectar]) or 1
        local zoneMultiplier = (planter.pollenMultipliers and planter.pollenMultipliers.Zones and planter.pollenMultipliers.Zones[fieldColor]) or 1
        local colorMultiplier = (planter.pollenMultipliers and planter.pollenMultipliers.Colors and planter.pollenMultipliers.Colors[fieldColor]) or 1
        local overallMultiplier = nectarMultiplier * zoneMultiplier * colorMultiplier

        if overallMultiplier > bestNectarMultiplier * bestZoneMultiplier then
            bestPlanter = planterName
            bestZone = fieldColor
            bestNectarMultiplier = nectarMultiplier
            bestZoneMultiplier = zoneMultiplier * colorMultiplier
        end
    end

    return bestPlanter, bestZone
end

function isNectarPending(nectarType)
    if not nectarType then
        return false
    end
    local planters = getMinePlanters()
    for _, v in pairs(planters) do
        if v.PotModel and v.PotModel.PrimaryPart then
            local location = findField(v.PotModel.PrimaryPart.Position)
            if location and NectarTypes and NectarTypes.PickForField then
                local configType = NectarTypes.PickForField(location.Name)
                if configType and configType .. " Nectar" == nectarType then
                    return true
                end
            end
        end
    end
    return false
end

function getBestNectarField(nectar)
    nectar = tostring(nectar or "")
    nectar = nectar:gsub(" Nectar", "")
    if not nectarsTable or not nectarsTable[nectar] then
        return nil
    end
    local bestField = nil
    for _, nectarField in pairs(nectarsTable[nectar]) do
        if not isFieldOccupied(nectarField) and nectarField ~= "Ant Field" then
            bestField = nectarField
        end
    end
    return bestField
end

function calculateLeastNectar()
    local blacklistedNectars = Pacific.autoPlantersSettings.blacklistedNectars or {}
    local leastNectar = nil
    local leastNectarTime = math.huge

    for _, v in pairs(nectarsDropdownTable or {}) do
        if table.find(blacklistedNectars, v) or isNectarPending(v) then
            continue
        end
        local currentNectarTime = getBuffTime(v)
        if currentNectarTime and currentNectarTime < leastNectarTime then
            leastNectar = v
            leastNectarTime = currentNectarTime
        end
    end
    return leastNectar
end

