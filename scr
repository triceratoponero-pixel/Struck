		oldt = hookfunction(getrenv().debug.traceback, function(lol)
			local traceback = oldt(lol)
			if checkcaller() then
				local a = traceback:split("\n")
				return string.format("%s\n%s\n", a[1], a[3])
			end
			return traceback
		end)

		local oldi
		oldi = hookfunction(getrenv().debug.info, function(lvl, a)
			if checkcaller() then
				return oldi(3, a)
			end
			return oldi(lvl, a)
		end)
	end

	-- Generic secureCall that works with any executor
	getgenv().secureCall = function(Function, Script, ...)
		assert(Script ~= nil and typeof(Script) == "Instance", string.format("invalid argument #1 to '%s' (Instance expected, got %s)", "secureCall", typeof(Script)))
		assert(Function ~= nil and typeof(Function) == "function", string.format("invalid argument #2 to '%s' (function expected, got %s)", "secureCall", typeof(Function)))
		assert(Script.ClassName == "LocalScript" or Script.ClassName == "ModuleScript", string.format("bad argument #3 to '%s' (LocalScript or ModuleScript expected, got %s)", "secureCall", Script.ClassName))

		return coroutine.wrap(function(...)
			local setidentity_func = set_thread_identity or setthreadcontext or setidentity
			if setidentity_func then
				setidentity_func(2)
			end
			local env = getsenv(Script)
			if env then
				setfenv(0, env)
				setfenv(1, env)
			end
			return Function(...)
		end)(...)
	end

	api = Pacific
end

