function getNumbers(str)
    local nums = {}
    for num in str:gmatch("%d+") do
        table.insert(nums, tonumber(num))
    end
    return nums
end

function truncate(num)
    num = tonumber(math.round(num))
    if num <= 0 then
        return 0
    end
    local suffixes = {"k", "M", "B", "T", "qd", "Qn", "sx", "Sp", "O", "N"}
    local i = 0
    while num > 999 and i < #suffixes do
        i = i + 1
        num = num / 1000
    end
    if i == 0 then
        return num
    end
    return (math.floor(num * 100) / 100) .. suffixes[i]
end

function truncatetime(sec)
    local second = tostring(sec % 60)
    local minute = tostring(math.floor(sec / 60 - math.floor(sec / 3600) * 60))
    local hour = tostring(math.floor(sec / 3600))
    return (#hour == 1 and "0" .. hour or hour) .. ":"
        .. (#minute == 1 and "0" .. minute or minute) .. ":"
        .. (#second == 1 and "0" .. second or second)
end

