function getQuestTasks(NPC)
    NPC = NPC or false
    local quests = getActiveQuests(NPC)
    local defeatMonstersTasks = {}
    local tasksToDo = {}

    for _, quest in pairs(quests) do
        local questData = getQuestInfo(quest)
        if not questData then
            continue
        end

        local questName = questData.Name
        if not Pacific.autoQuestSettings.doRepeatables and questData.Repeatable then
            continue
        end

        local questProgress = getQuestProgress(questName)
        if not questProgress then
            continue
        end

        for index, questTask in pairs(questProgress) do
            local iscompleted = questTask[1]
            if iscompleted >= 1 then
                continue
            end

            local fullTask = questData.Tasks[index]
            if not fullTask then
                continue
            end
            fullTask.Progress = questTask

            local taskDescription = fullTask.Description
            if typeof(taskDescription) ~= "string" then
                if setIdentity then
                    setIdentity(2)
                end
                taskDescription = taskDescription(getClientStatCache())
                if setIdentity then
                    setIdentity(origThreadIdentity)
                end
            end

            local add = false
            if fullTask.Type == "Collect Pollen" and Pacific.autoQuestSettings.farmPollen
                or fullTask.Type == "Collect Goo" and Pacific.autoQuestSettings.farmGoo
                or fullTask.Type == "Defeat Monsters" and Pacific.autoQuestSettings.killMobs
                or fullTask.Type == "Use Toy" and Pacific.autoQuestSettings.useToys
                or fullTask.Type == "Match Pairs" and Pacific.autoQuestSettings.useMemoryMatch
                or fullTask.Type == "Complete Quests" and Pacific.autoQuestSettings.doQuestQuests
                or fullTask.Type == "Use Items" and taskDescription and taskDescription:find("Feed") and Pacific.autoQuestSettings.feedBees
            then
                add = true
            end

            if not add then
                continue
            end

            if fullTask.Type == "Defeat Monsters" then
                table.insert(defeatMonstersTasks, fullTask)
            else
                table.insert(tasksToDo, fullTask)
            end
        end
    end

    if Pacific.autoQuestSettings.prioritizeMobKill then
        for _, task in ipairs(defeatMonstersTasks) do
            table.insert(tasksToDo, 1, task)
        end
    else
        for _, task in ipairs(defeatMonstersTasks) do
            table.insert(tasksToDo, task)
        end
    end

    return tasksToDo
end

function getQuestTaskField(questTask)
    if not questTask then
