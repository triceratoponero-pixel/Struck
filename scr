function getBestPuffshroom()
    local happenings = Workspace:FindFirstChild("Happenings")
    if not happenings then
        return nil
    end
    local puffshrooms = happenings:FindFirstChild("Puffshrooms")
    if not puffshrooms then
        return nil
    end

    local puffs = puffshrooms:GetChildren()
    if #puffs == 0 then
        return nil
    end

    local bestPuffs = {}
    local maxRarity = Pacific.autoPuffshroomSettings.rarityPriority == "Mythic > Common" and 0 or 6

    for _, puff in ipairs(puffs) do
