            puffLevel > Pacific.autoPuffshroomSettings.maximumLevel or
            not puff:FindFirstChild("Puffball Stem") or
            not findField(puff["Puffball Stem"].Position) then
            continue
        end

        local rarityValue = puffsRarityList[puffRarity] or 1
        local priority = Pacific.autoPuffshroomSettings.rarityPriority

        if (priority == "Mythic > Common" and rarityValue > maxRarity) or
            (priority == "Common > Mythic" and rarityValue < maxRarity) then
            maxRarity = rarityValue
            bestPuffs = { puff }
        elseif rarityValue == maxRarity then
            table.insert(bestPuffs, puff)
        end
    end

    table.sort(bestPuffs, function(a, b)
