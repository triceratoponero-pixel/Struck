            end
            task.wait()
        end
        collectNearestTokens()
    end
end

function farmSprout(sprout, field)
    if not sprout or not sprout.Parent or not Pacific.autoFarmSettings.farmSprouts then
        return false
    end

    local farmed = false
    while sprout and sprout.Parent and Pacific.autoFarmSettings.farmSprouts and Pacific.toggles.autofarm do
        if getBagPercentage() >= 99 then
            convertHoney()
        end
        if findField(api.humanoidrootpart().Position) ~= field then
            moveTo(field.Position)
            task.wait()
        end
        collectNearestTokens(field.Position, 60)
        farmed = true
        task.wait()
    end

    return Pacific.autoFarmSettings.farmSprouts and Pacific.toggles.autofarm and farmed
end

function farmSprouts()
    if not next(temptable.sproutsTable) then
        return
    end
    while next(temptable.sproutsTable) and Pacific.autoFarmSettings.farmSprouts and Pacific.toggles.autofarm do
        local key, sprout = next(temptable.sproutsTable)
        if sprout and sprout.Model and sprout.Model.Parent then
            if farmSprout(sprout.Model, sprout.Field) then
                for _ = 1, 30 do
                    collectNearestTokens(sprout.Field.Position, 100)
                    task.wait()
                end
            end
        else
            temptable.sproutsTable[key] = nil
        end
        task.wait()
    end
end

function selectField(fieldName)
    if fieldName == nil then
        temptable.fieldSelected = nil
        temptable.fieldPosition = nil
        return "Unselected field"
    end
    if temptable.fieldSelected and temptable.fieldSelected.Name == fieldName then
        return "Field already selected"
    end

    local flowerZones = Workspace:FindFirstChild("FlowerZones")
    if flowerZones then
        temptable.fieldSelected = flowerZones:FindFirstChild(fieldName) or flowerZones:FindFirstChild("Dandelion Field")
    else
        temptable.fieldSelected = nil
    end

    if temptable.fieldSelected then
        temptable.fieldPosition = temptable.fieldSelected.Position
    else
        temptable.fieldPosition = nil
    end
end

