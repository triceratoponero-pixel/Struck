function prioritizeQuests(quests)
    local prioritizedQuests = {}
    local tempQuestsTable = {}
    for _, questData in pairs(quests) do
        local prio = getQuestSetting(questData.npc, "prio") or 101
        table.insert(tempQuestsTable, {prio, questData.Name, questData.npc})
    end
    table.sort(tempQuestsTable, function(a, b)
        if a[1] == b[1] then
            return a[2] < b[2]
        else
            return a[1] < b[1]
        end
    end)
    for _, v in ipairs(tempQuestsTable) do
        table.insert(prioritizedQuests, v[2])
    end
    return prioritizedQuests
end

function getActiveQuests(NPC)
    local quests = {}
    local activeQuests = getClientStatCache("Quests", "Active")
    if not activeQuests then
        return {}
    end

    for _, v in pairs(activeQuests) do
