function getTokenLink()
    local nearestTokenLink = { token = nil, distance = math.huge }
    if not temptable.tokenpath then
        return nil
    end

    local hrp = api.humanoidrootpart()
    if not hrp then
        return nil
    end

    for _, token in ipairs(temptable.tokenpath:GetChildren()) do
        if getTokenId(token) == "1629547638" and token.CFrame.YVector.Y == 1 and not token:FindFirstChild("Collected") then
            local distance = (token.Position - hrp.Position).Magnitude
            if distance < nearestTokenLink.distance then
                nearestTokenLink = { token = token, distance = distance }
            end
        end
    end
    return nearestTokenLink.token
end

function collectToken(token)
    if not token or not token.Parent or token:FindFirstChild("Collected") then
        return false
    end

    local startedCollecting = tick()
    local moveToCalled = -1
    local collected = false
    local hrp = api.humanoidrootpart()
    if not hrp then
        return false
    end

    while true do
        local tokenPos = token.Position
        local hrpPos = hrp.Position
        local dist = (hrpPos - tokenPos).Magnitude

        -- FIX: Updated to workspace:Raycast instead of deprecated Ray.new
        local raycastParams = RaycastParams.new()
        raycastParams.FilterType = Enum.RaycastFilterType.Whitelist
        raycastParams.FilterDescendantsInstances = { token }
        local rayResult = workspace:Raycast(hrpPos, tokenPos - hrpPos, raycastParams)
        local canSeeToken = rayResult and rayResult.Instance == token

        if dist < 4 or
            token.CFrame.YVector.Y ~= 1 or
            not canSeeToken or
            dist < 4 or
            (tick() - startedCollecting) >= 3 then
            if (tick() - startedCollecting) >= 3 then
                break
            end
            collected = true
            break
        elseif dist > 200 then
            break
        end

        if tick() - moveToCalled > 0.25 then
            if (tick() - temptable.lastTweenToRare) < 5 then
                break
            end
            local hum = api.humanoid()
            if hum then
                local success = pcall(function()
                    hum:MoveTo(tokenPos)
                end)
                if not success then
                    break
                end
            else
                break
            end
            moveToCalled = tick()
        end

        task.wait()
    end

    if collected then
        markAsCollected(token)
        return true
    else
        return false
    end
end

function farmToken(customCallback)
    local nearestTokenLink = getTokenLink()
    if nearestTokenLink then
        collectToken(nearestTokenLink)
        return true
    else
        local tokenToCollect = NearestTable.getNearestToken(nil, function(token)
            if customCallback and not customCallback(token) then
                return false
            end
            if token.CFrame.YVector.Y == 1 and not token:FindFirstChild("Collected") and not table.find(temptable.susTokenPositions, token.Position) then
                return true
            end
            return false
        end)
        if not tokenToCollect then
            return false
        end
        collectToken(tokenToCollect)
        return true
    end
end

