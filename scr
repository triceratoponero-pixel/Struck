function avoidWarningDisks()
    local hrp = api.humanoidrootpart()
    if not hrp then
        return false
    end
    local playerPos = hrp.Position
    local warningDisks = getWarningDisks()
    if #warningDisks == 0 then
        task.wait()
        return false
    end

    -- FIX: Updated to workspace:Raycast instead of deprecated Ray.new
    local origin = playerPos + Vector3.new(0, 100, 0)
    local direction = Vector3.new(1, -735, 1)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Whitelist
    raycastParams.FilterDescendantsInstances = warningDisks
    local result = workspace:Raycast(origin, direction, raycastParams)
    local touchedWarningDisk = result and result.Instance

    if touchedWarningDisk then
        local diskRadius = touchedWarningDisk.Size.X / 2
        local dirToPlayer = (playerPos - touchedWarningDisk.Position).Unit

        -- Calculate the safe position to move to
        local diskCenter = touchedWarningDisk.Position
        local playerToCenter = (playerPos - diskCenter).Magnitude
        local playerToDisk = playerToCenter - diskRadius
        local safePos = diskCenter + dirToPlayer * (diskRadius + 4 + playerToDisk + 5)

        if (safePos - hrp.Position).Magnitude < 0.5 then
            safePos = hrp.Position + Vector3.new(1, 0, 0)
        end

        local hum = api.humanoid()
        if hum then
            hum:MoveTo(safePos + Vector3.new(1, 0, 1))
        end
        task.wait()
        return true
    end
    task.wait()
    return false
end

function shouldIConvert(converting, check1)
    check1 = check1 ~= false -- Default to true if nil
    local timeSinceLastFullBag = tick() - temptable.lastFullBag

    -- Check if the user wants to wait before converting, and if enough time has elapsed
    if timeSinceLastFullBag < Pacific.convertSettings.secondsBeforeConvert then
        return false
    end

    local bagPercent = getBagPercentage()

    -- Check if the bag is full or if the user wants to convert manually
    if converting and bagPercent > 0 or bagPercent >= Pacific.convertSettings.convertat then
        if Pacific.convertSettings.instantToggle and check1 then
            instaConvFunc()
            task.wait(1.5)
            return shouldIConvert()
        end
        return true
    else
        if temptable.puffsDetected and Pacific.autoPuffshroomSettings.farmPuffshrooms then
            return false
        end

        if Pacific.toggles.converthiveballoon and gethiveballoon() then
            if Pacific.convertSettings.convertballoonat == 0 and converting then
                return true
            elseif Pacific.convertSettings.convertballoonat ~= 0 then
                local buffTime = tonumber(getBuffTime("Balloon Blessing")) or 0
                if (buffTime / 60) <= Pacific.convertSettings.convertballoonat then
                    return true
                else
                    return false
                end
            else
                return false
            end
        else
            return false
        end
    end
end

function getBagPercentage()
    local coreStats = player:FindFirstChild("CoreStats")
    if not coreStats then
        return 0
    end

    local pollenStat = coreStats:FindFirstChild("Pollen")
    local capacityStat = coreStats:FindFirstChild("Capacity")
    local pollencount = pollenStat and pollenStat.Value or 0
    local maxpollen = capacityStat and capacityStat.Value or 1

    if maxpollen == 0 then
        return 0
    end

    local percentage = (pollencount / maxpollen) * 100

    if temptable.lastFullBag == 0 and percentage >= Pacific.convertSettings.convertat then
        temptable.lastFullBag = tick()
    elseif percentage < Pacific.convertSettings.convertat then
        temptable.lastFullBag = 0
    end

    return percentage
end

