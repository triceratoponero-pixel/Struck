-- TASK PRIORITY SYSTEM
-- ============================================

function getNearestTask(callback)
    local nearest = { taskName = "", distance = math.huge, object = nil }
    local distanceTable = {}

    for taskKey, finderFunc in pairs(NearestTable) do
        if not canFarmTask(taskKey) then
            continue
        end

        local tempName = string.gsub(taskKey, "getNearest", "")
        local values
        if taskKey == "getNearestToken" then
            values = { finderFunc(nil, callback) }
        else
            values = { finderFunc(callback) }
        end

        local tableToAdd = { tempName, taskKey, values[1], values[2] }
        table.insert(distanceTable, tableToAdd)
    end

    for _, entry in ipairs(distanceTable) do
        if entry[4] < nearest.distance then
            nearest = { taskName = entry[1], distance = entry[4], object = entry[3] }
        end
    end

    return nearest.taskName, nearest.object
end

function farmNearest(callback)
    local nearestName = getNearestTask(callback)
    if nearestName == "Bubble" then
        return farmBubble(callback)
    elseif nearestName == "Token" then
        return farmToken(callback)
    elseif nearestName == "Fuzz" then
        return farmFuzzy(callback)
    end
    return false
end

