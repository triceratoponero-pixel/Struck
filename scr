local cachedFieldFlowers = {}

function getAllFlowers(field)
    if not field then
        return nil
    end
    local idValue = field:FindFirstChild("ID")
    if not idValue then
        return nil
    end
    local fieldId = idValue.Value
    local fieldFlowers
    if cachedFieldFlowers[field.Name] then
        fieldFlowers = cachedFieldFlowers[field.Name]
    else
        fieldFlowers = {}
        local flowersFolder = Workspace:FindFirstChild("Flowers")
        if flowersFolder then
            for _, flower in pairs(flowersFolder:GetChildren()) do
                local flowerInfo = getNumbers(flower.Name)
                if #flowerInfo == 3 and flowerInfo[1] == fieldId then
                    table.insert(fieldFlowers, flower)
                end
            end
        end
        if #fieldFlowers > 1 then
            cachedFieldFlowers[field.Name] = fieldFlowers
        else
            return nil
        end
    end
    return fieldFlowers
end

function getRandomFlower(field)
    local flowers = getAllFlowers(field)
    if not flowers or #flowers == 0 then
        return nil
    end
    return flowers[math.random(1, #flowers)]
end

local cachedFieldCenters = {farm = {}, sprinkler = {}}

function getNewFarmCenter(field, sprinkler)
    if not field then
        return nil
    end
    local colorGroup = field:FindFirstChild("ColorGroup")
    if not colorGroup or colorGroup.Value ~= "Blue" then
        return nil
    end

    local cacheKey = sprinkler and "sprinkler" or "farm"
    if cachedFieldCenters[cacheKey][field.Name] then
        return cachedFieldCenters[cacheKey][field.Name]
    end

    local flowers = getAllFlowers(field)
    if not flowers then
        return nil
    end

    local minX, minY = math.huge, math.huge
    local maxX, maxY = -math.huge, -math.huge

    for _, flower in ipairs(flowers) do
        local flowerSettings = getNumbers(flower.Name)
        if #flowerSettings >= 3 then
            minX = math.min(minX, flowerSettings[2])
            minY = math.min(minY, flowerSettings[3])
            maxX = math.max(maxX, flowerSettings[2])
            maxY = math.max(maxY, flowerSettings[3])
        end
    end

    local fieldId = field.ID.Value
    local centerFlowerX = sprinkler and maxX - 5 or maxX
    local centerFlowerY = sprinkler and maxY - 5 or maxY
    local flowerCenter

    for _, flower in pairs(flowers) do
        if flower.Name == "FP" .. fieldId .. "-" .. centerFlowerX .. "-" .. centerFlowerY then
            flowerCenter = flower
            break
        end
    end

    if flowerCenter then
        cachedFieldCenters[cacheKey][field.Name] = flowerCenter
    end
    return flowerCenter
end

