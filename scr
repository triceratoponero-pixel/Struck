function collectAllPlanters(collectPercentage)
    local plantersToCollect = {}
    local minePlanters = getMinePlanters()

    for _, planter in pairs(minePlanters) do
        if planter.GrowthPercent ~= nil then
            local threshold = (collectPercentage or Pacific.autoPlantersSettings.planterHarvestAt) / 100
            if planter.GrowthPercent >= threshold then
                table.insert(plantersToCollect, {
                    PM = planter.PotModel and planter.PotModel.PrimaryPart,
                    AID = planter.ActorID
                })
            end
        end
    end

    if #plantersToCollect > 0 then
        for _, planter in pairs(plantersToCollect) do
            if not planter.PM or not planter.AID then
                continue
            end
            while isPlanterExists(planter.AID) do
                collectSpecificPlanter(planter.PM, planter.AID)
                task.wait(1)
            end
        end
    end
end

function getPlantersCacheFromFile()
    local HttpService = game:GetService("HttpService")
    if not isfile(plantersCacheFilePath) then
        local defaultPlantersCache = {
            customPlanters1 = 1,
            customPlanters2 = 1,
            customPlanters3 = 1
        }
        local success, encoded = pcall(function()
            return HttpService:JSONEncode(defaultPlantersCache)
        end)
        if success then
            writefile(plantersCacheFilePath, encoded)
        end
    end
    local fileContent = readfile(plantersCacheFilePath)
    local success, decoded = pcall(function()
        return HttpService:JSONDecode(fileContent)
    end)
    if success then
        return decoded
    end
    return {customPlanters1 = 1, customPlanters2 = 1, customPlanters3 = 1}
end

function getPlantersCache()
    local Cache = plantersCache
    local isFromCache = true
    if not Cache then
        isFromCache = false
        Cache = getPlantersCacheFromFile()
        plantersCache = Cache
    end
    return Cache
end

function updatePlantersCache(cycle, newValue)
    local Cache = getPlantersCache()
    Cache["customPlanters" .. cycle] = newValue
    plantersCache = Cache
    local HttpService = game:GetService("HttpService")
    local success, encoded = pcall(function()
        return HttpService:JSONEncode(Cache)
    end)
    if success then
        writefile(plantersCacheFilePath, encoded)
    end
end

function checkIfPlanted(stepTable)
    if not stepTable then
        return false, nil
    end
    local isPlanted = false
    local planter = nil
    local minePlanters = getMinePlanters()

    for _, v in pairs(minePlanters) do
        local planterData = getPlanterData(v.Type)
        if not planterData then
            continue
        end
        local planterName = planterData.displayName
        local planterField = findField(v.Pos)
        local fieldName = planterField and planterField.Name

        if stepTable.field == fieldName and stepTable.planter == planterName then
            isPlanted = true
            planter = v
            break
        end
    end
    return isPlanted, planter
end

function isPlanterInConfig(planter)
    if not planter or not planter.Name or not planter.Field then
        return false
    end
    for i = 1, 3 do
        local cycleName = "customPlanters" .. i
        local stepsTable = Pacific.customPlanterSettings[cycleName]
        if not stepsTable then
            continue
        end
        for j = 1, 5 do
            local stepTable = stepsTable[j]
            if not stepTable then
                continue
            end
            local hasPlanter = stepTable.planter and table.find(plantersDropdownTable, stepTable.planter)
            local hasField = stepTable.field and table.find(fieldsTable, stepTable.field)
            if not hasPlanter or not hasField then
                continue
            end
            local stepPlanterData = getPlanterData(stepTable.planter)
            if not stepPlanterData then
                continue
            end
            if stepPlanterData.displayName == planter.Name and stepTable.field == planter.Field then
                return true
            end
        end
    end
    return false
end

function autoPlanters()
    local shouldReturn = false
    if not Pacific.autoPlantersSettings.doCustomPlanters then
        return shouldReturn
    end

    local planterCycles = Pacific.customPlanterSettings
    local steps = {
        customPlanters1 = 5,
        customPlanters2 = 5,
        customPlanters3 = 5
    }

    -- Count valid steps per cycle
    for i = 1, 3 do
        local cycleName = "customPlanters" .. i
        local stepsTable = planterCycles[cycleName]
        if not stepsTable then
            steps[cycleName] = 0
            continue
        end
        for j = 1, 5 do
            local stepTable = stepsTable[j]
            if not stepTable then
                steps[cycleName] = steps[cycleName] - 1
                continue
            end
            local hasPlanter = stepTable.planter and table.find(plantersDropdownTable, stepTable.planter)
            local hasField = stepTable.field and table.find(fieldsTable, stepTable.field)
            if not hasPlanter or not hasField then
                steps[cycleName] = steps[cycleName] - 1
            else
                local isPlanted = checkIfPlanted(stepTable)
                if isPlanted then
                    updatePlantersCache(i, j)
                    break
                end
            end
        end
    end

    -- Collect planters not in config
    local minePlanters = getMinePlanters()
    for _, planter in pairs(minePlanters) do
        local planterData = getPlanterData(planter.Type)
        if not planterData then
            continue
        end
        local planterName = planterData.displayName
        local planterField = findField(planter.Pos)
        local fieldName = planterField and planterField.Name

        if not isPlanterInConfig({Name = planterName, Field = fieldName}) then
            if planter.PotModel and planter.PotModel.PrimaryPart and planter.ActorID then
                collectSpecificPlanter(planter.PotModel.PrimaryPart, planter.ActorID)
                shouldReturn = true
            end
        end
    end

    -- Plant new planters
    local currentSteps = getPlantersCache()
    for i = 1, 3 do
        local cycleName = "customPlanters" .. i
        local stepsTable = planterCycles[cycleName]
        if not stepsTable then
            continue
        end
        if steps[cycleName] == 0 then
            continue
        end

        local currentStep = currentSteps[cycleName] or 1
        local config = stepsTable[currentStep]
        if not config then
            continue
        end

        if currentStep > steps[cycleName] then
            currentStep = 1
            updatePlantersCache(i, 1)
            currentSteps = getPlantersCache()
        end

        local isPlanted, existingPlanter = checkIfPlanted(config)
        if not isPlanted and #getMinePlanters() < 3 then
            local planter = config.planter
            if not planter then
                continue
            end
            if planter:find("Plenty") then
                planter = "The Planter Of Plenty"
            elseif not table.find(plantersDropdownTable, planter) then
                continue
            end

            local planterData = getPlanterData(planter)
            if not planterData then
                continue
            end

            local planterKey = planter:find("Plenty") and "Plenty" or planterData.systemName
            local planterCount = getClientStatCache("Eggs", planterKey .. "Planter") or 0

            if isFieldOccupied(config.field) or planterCount <= 0 or isPlanterPlanted(planterData.systemName) then
                warn("[Pacific] Skipped", cycleName, planter, config.field)
                updatePlantersCache(i, currentStep + 1)
                currentSteps = getPlantersCache()
            else
                plantPlanter(planterData.systemName, config.field)
                task.wait()
                shouldReturn = true
            end
        elseif isPlanted and existingPlanter and existingPlanter.GrowthPercent then
            local harvestThreshold = (config.harvestAmount or 75) / 100
            if existingPlanter.GrowthPercent >= harvestThreshold then
                local potModel = existingPlanter.PotModel
                if potModel and potModel.PrimaryPart then
                    local potField = findField(potModel.PrimaryPart.Position)
                    if potField and potField.Name == config.field then
                        collectSpecificPlanter(potModel.PrimaryPart, existingPlanter.ActorID)
                        updatePlantersCache(i, currentStep + 1)
                        currentSteps = getPlantersCache()
                        shouldReturn = true
                    end
                end
            end
        end
    end

    return shouldReturn
end

